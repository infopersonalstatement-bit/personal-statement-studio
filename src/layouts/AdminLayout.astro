---
import '../styles/global.css';
import ThemeToggle from '../components/common/ThemeToggle.astro';
import SocialSticky from '../components/common/SocialSticky.astro';

const user = Astro.locals.user;
const isAdmin = Astro.locals.isAdmin;
if (!user || !isAdmin) return Astro.redirect('/dashboard');

interface Props {
  title: string;
  activeNav?: 'overview' | 'prodotti' | 'bundles' | 'blog' | 'analytics' | 'categorie';
}

const { title, activeNav } = Astro.props;

const navItems = [
  { href: '/',                 label: 'Home',           id: 'home' },
  { href: '/admin',            label: 'Panoramica',     id: 'overview' },
  { href: '/admin/analytics',  label: 'Analytics',      id: 'analytics' },
  { href: '/admin/prodotti',   label: 'Prodotti & PDF', id: 'prodotti' },
  { href: '/admin/bundles',    label: 'Bundle',         id: 'bundles' },
  { href: '/admin/blog',       label: 'Blog',           id: 'blog' },
  { href: '/admin/categorie',  label: 'Categorie & Tag',id: 'categorie' },
];
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/logo.png" />
    <title>{title} | Admin · Personal Statement Studio</title>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>

  <body
    class="flex min-h-screen flex-col antialiased transition-colors duration-200"
    style="background-color: var(--bg); color: var(--text);"
  >

    <!-- Top bar -->
    <header
      class="sticky top-0 z-50 flex items-center justify-between px-6 py-3 backdrop-blur-md transition-colors duration-200"
      style="background-color: color-mix(in srgb, var(--bg) 85%, transparent); border-bottom: 1px solid var(--border);"
    >
      <div class="flex items-center gap-3">
        <a href="/" aria-label="Home">
          <img src="/logo.png" alt="" class="h-9 w-auto opacity-80 hover:opacity-100 transition-opacity"
            style="filter: drop-shadow(0 2px 8px color-mix(in srgb, var(--gold) 40%, transparent));" />
        </a>
        <div>
          <span class="block text-[10px] uppercase tracking-[0.22em]" style="color: var(--text-muted);">Personal Statement</span>
          <span class="block text-xs font-semibold uppercase tracking-widest" style="color: var(--gold);">Admin Panel</span>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <span class="hidden sm:block text-xs uppercase tracking-widest" style="color: var(--text-muted);">{user.email}</span>
        <ThemeToggle />
        <a
          href="/dashboard"
          class="rounded-full border px-4 py-1.5 text-xs font-semibold uppercase tracking-widest transition-all duration-200"
          style="border-color: var(--border); color: var(--text-muted);"
          onmouseover="this.style.borderColor='var(--gold)'; this.style.color='var(--gold)'"
          onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-muted)'"
        >
          Area utente
        </a>
        <form action="/api/auth/signout" method="POST">
          <button
            type="submit"
            class="rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-widest transition-all duration-200"
            style="background-color: var(--gold); color: #0F0D0A;"
            onmouseover="this.style.backgroundColor='var(--gold-hover)'"
            onmouseout="this.style.backgroundColor='var(--gold)'"
          >
            Esci
          </button>
        </form>
      </div>
    </header>

    <!-- Barra navigazione secondaria admin — scorrevole su mobile -->
    <nav
      class="border-b transition-colors duration-200"
      style="border-color: var(--border); background-color: color-mix(in srgb, var(--surface) 40%, transparent);"
    >
      <div class="flex items-center gap-2 overflow-x-auto px-4 py-3 scrollbar-hide"
        style="-webkit-overflow-scrolling: touch; scroll-snap-type: x proximity;">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="nav-pill flex-shrink-0"
            style={activeNav === item.id ? 'color: var(--gold); border-color: var(--gold);' : ''}
          >
            {item.label}
          </a>
        ))}
      </div>
    </nav>

    <!-- Contenuto -->
    <main class="flex-1 px-6 py-10 sm:px-10 max-w-5xl mx-auto w-full">
      <div class="mb-10 border-b pb-6" style="border-color: var(--border);">
        <p class="mb-1 text-[10px] font-semibold uppercase tracking-[0.25em]" style="color: var(--gold);">Admin</p>
        <h1 class="font-display text-3xl font-light" style="color: var(--text);">{title}</h1>
      </div>
      <slot />
    </main>

    <footer class="border-t py-4 text-center text-xs transition-colors duration-200"
      style="border-color: var(--border); color: var(--text-muted);">
      © {new Date().getFullYear()} Personal Statement Studio · Admin
    </footer>

    <SocialSticky />
  </body>
</html>
