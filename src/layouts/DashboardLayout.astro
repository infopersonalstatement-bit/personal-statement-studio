---
import '../styles/global.css';
import ThemeToggle from '../components/common/ThemeToggle.astro';
import SocialHeader from '../components/common/SocialHeader.astro';
import SocialSticky from '../components/common/SocialSticky.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

// Nome visualizzato: nome dal profilo se compilato, altrimenti email
const { data: profilo } = await Astro.locals.supabase
  .from('utenti')
  .select('nome')
  .eq('id', user.id)
  .maybeSingle();

const displayName = profilo?.nome?.trim() || user.email;

interface Props {
  title: string;
  activeNav?: 'acquisti' | 'impostazioni';
}

const { title, activeNav } = Astro.props;

const navItems = [
  { href: '/',                       label: 'Home',            id: 'home' },
  { href: '/dashboard',              label: 'I miei acquisti', id: 'acquisti' },
  { href: '/dashboard/impostazioni', label: 'Impostazioni',    id: 'impostazioni' },
];
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/logo.png" />
    <title>{title} | Personal Statement Studio</title>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>

  <body
    class="flex min-h-screen flex-col antialiased transition-colors duration-200"
    style="background-color: var(--bg); color: var(--text);"
  >

    <!-- Top bar -->
    <header
      class="sticky top-0 z-50 relative flex items-center justify-between px-6 py-3 backdrop-blur-md transition-colors duration-200"
      style="background-color: color-mix(in srgb, var(--bg) 85%, transparent); border-bottom: 1px solid var(--border);"
    >
      <a href="/" class="group relative z-10 flex items-center gap-3" aria-label="Home">
        <img
          src="/logo.png"
          alt="Personal Statement Studio"
          class="h-9 w-auto transition-all duration-300 group-hover:scale-105"
          style="filter: drop-shadow(0 2px 10px color-mix(in srgb, var(--gold) 50%, transparent));"
        />
        <span class="hidden sm:block font-display leading-tight">
          <span class="block text-[10px] uppercase tracking-[0.22em]" style="color: var(--text-muted);">Personal Statement</span>
          <em class="not-italic text-sm font-light tracking-widest" style="color: var(--gold);">Studio</em>
        </span>
      </a>

      <div class="pointer-events-none absolute left-1/2 top-1/2 z-0 -translate-x-1/2 -translate-y-1/2">
        <SocialHeader />
      </div>

      <div class="relative z-10 flex items-center gap-3">
        <span class="hidden sm:block text-xs tracking-wide" style="color: var(--text-muted);">
          {displayName}
        </span>
        <ThemeToggle />
        <form action="/api/auth/signout" method="POST">
          <button
            type="submit"
            class="rounded-full border px-4 py-1.5 text-xs font-semibold uppercase tracking-widest transition-all duration-200"
            style="border-color: var(--border); color: var(--text-muted);"
            onmouseover="this.style.borderColor='var(--gold)'; this.style.color='var(--gold)'"
            onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-muted)'"
          >
            Esci
          </button>
        </form>
      </div>
    </header>

    <!-- Barra navigazione secondaria — stile pill coerente col sito -->
    <nav
      class="flex items-center justify-center gap-2 border-b px-6 py-3 transition-colors duration-200"
      style="border-color: var(--border); background-color: color-mix(in srgb, var(--surface) 40%, transparent);"
    >
      {navItems.map((item) => (
        <a
          href={item.href}
          class="nav-pill"
          style={activeNav === item.id ? 'color: var(--gold); border-color: var(--gold);' : ''}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Contenuto principale -->
    <main class="flex-1 px-6 py-10 sm:px-10 max-w-5xl mx-auto w-full">

      <div class="mb-10 border-b pb-6" style="border-color: var(--border);">
        <p class="mb-1 text-[10px] font-semibold uppercase tracking-[0.25em]" style="color: var(--gold);">
          Area riservata
        </p>
        <h1 class="font-display text-3xl font-light" style="color: var(--text);">{title}</h1>
      </div>

      <slot />

    </main>

    <footer
      class="border-t py-4 text-center text-xs transition-colors duration-200"
      style="border-color: var(--border); color: var(--text-muted);"
    >
      © {new Date().getFullYear()} Personal Statement Studio
      <span class="mx-2">·</span>
      <a href="/privacy" style="color: var(--text-muted); transition: color 0.2s;"
         onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--text-muted)'">
        Privacy
      </a>
    </footer>

    <SocialSticky />
  </body>
</html>
