---
import '../styles/global.css';
import ThemeToggle from '../components/common/ThemeToggle.astro';
import SocialSticky from '../components/common/SocialSticky.astro';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'product';
}

const {
  title,
  description = 'Non produciamo contenuti. Costruiamo percezione. Strumenti strategici per imprenditori, creator e professionisti.',
  ogImage = '/og-default.jpg',
  ogType = 'website',
} = Astro.props;

const user = Astro.locals.user;
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || '').replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, siteUrl || 'https://personalstatementstudio.com');
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Personal Statement Studio`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Personal Statement Studio" />
    <meta property="og:locale" content="it_IT" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Personal Statement Studio`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Slot JSON-LD (struttura dati schema.org) -->
    <slot name="jsonld" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/png" href="/logo.png" />
    <title>{title} | Personal Statement Studio</title>

    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>

  <body
    class="flex min-h-screen flex-col transition-colors duration-200"
    style="background-color: var(--bg); color: var(--text);"
  >

    <!-- ╔══════════════════════════════════════════════════════════════╗
         ║  TOP BAR — fixed full-width, sempre visibile             ║
         ║  Logo (→ home) a sinistra · Toggle + Accedi a destra     ║
         ╚══════════════════════════════════════════════════════════════╝ -->
    <header
      class="fixed left-0 right-0 top-0 z-[100] flex items-center justify-between px-6 py-3 backdrop-blur-md transition-colors duration-200"
      style="background-color: color-mix(in srgb, var(--bg) 82%, transparent); border-bottom: 1px solid var(--border);"
    >
      <!-- Logo → home -->
      <a href="/" class="group flex items-center gap-3" aria-label="Torna alla home">
        <img
          src="/logo.png"
          alt="Personal Statement Studio"
          class="h-9 w-auto transition-all duration-300 group-hover:scale-105"
          style="filter: drop-shadow(0 2px 10px color-mix(in srgb, var(--gold) 50%, transparent));"
        />
        <span class="hidden sm:block font-display leading-tight">
          <span class="block text-[10px] uppercase tracking-[0.22em]" style="color: var(--text-muted);">Personal Statement</span>
          <em class="not-italic text-sm font-light tracking-widest" style="color: var(--gold);">Studio</em>
        </span>
      </a>

      <!-- Actions -->
      <div class="flex items-center gap-2">
        <ThemeToggle />
        {user ? (
          <a
            href="/dashboard"
            class="hero-pill rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-widest"
            style="background-color: var(--gold); color: #0F0D0A;"
          >
            Area riservata
          </a>
        ) : (
          <a
            href="/auth/login"
            class="hero-pill rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-widest"
            style="background-color: var(--gold); color: #0F0D0A;"
          >
            Accedi
          </a>
        )}
      </div>
    </header>

    <!-- Spacer per compensare la top bar fixed -->
    <div class="h-[61px]"></div>

    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer
      class="border-t py-12 transition-colors duration-200"
      style="border-color: var(--border); background-color: var(--bg-surface);"
    >
      <div class="mx-auto max-w-6xl px-6">
        <div class="flex flex-col items-center gap-6 sm:flex-row sm:justify-between">
          <a href="/" class="group flex items-center gap-3">
            <img
              src="/logo.png"
              alt="Personal Statement Studio"
              class="h-10 w-auto opacity-80 transition-opacity group-hover:opacity-100"
              style="filter: drop-shadow(0 1px 6px color-mix(in srgb, var(--gold) 30%, transparent));"
            />
            <span class="font-display text-xs uppercase tracking-[0.2em]" style="color: var(--text-muted);">
              Personal Statement Studio
            </span>
          </a>
          <nav class="flex gap-6">
            {[
              { href: '/shop',      label: 'Prodotti' },
              { href: '/blog',      label: 'Blog' },
              { href: '/manifesto', label: 'Manifesto' },
            ].map(l => (
              <a
                href={l.href}
                class="text-xs uppercase tracking-widest transition-colors duration-200"
                style="color: var(--text-muted);"
                onmouseover="this.style.color='var(--gold)'"
                onmouseout="this.style.color='var(--text-muted)'"
              >{l.label}</a>
            ))}
          </nav>
        </div>
        <div class="mt-8 border-t pt-6 text-center text-xs" style="border-color: var(--border); color: var(--text-muted);">
          <p>© {new Date().getFullYear()} Personal Statement Studio · Tutti i diritti riservati</p>
          <div class="mt-2 flex justify-center gap-4">
            <a href="/privacy" style="color: var(--text-muted); transition: color 0.2s;"
               onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--text-muted)'">
              Privacy Policy
            </a>
            <a href="/data-deletion" style="color: var(--text-muted); transition: color 0.2s;"
               onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--text-muted)'">
              Cancellazione Dati
            </a>
          </div>
        </div>
      </div>
    </footer>

  <SocialSticky />
  <Analytics />

  <script is:inline>
    (function () {
      function initScrollReveal() {
        var nodes = document.querySelectorAll('.scroll-reveal:not(.is-visible)');
        if (!nodes.length) return;

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          nodes.forEach(function (el) { el.classList.add('is-visible'); });
          return;
        }

        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -5% 0px' });

        nodes.forEach(function (el) { observer.observe(el); });
      }

      initScrollReveal();
      document.addEventListener('astro:page-load', initScrollReveal);
    })();
  </script>
  </body>
</html>
