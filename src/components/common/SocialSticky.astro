---
import { SOCIAL_LINKS } from '../../lib/social-links';
import LangSelector from './LangSelector.astro';

const lang = Astro.locals.lang ?? 'it';
const t    = Astro.locals.t ?? ((k: string) => k);
---

<!-- Barra fissa in basso — social + selettore lingua -->
<nav
  class="social-sticky-bar fixed bottom-0 left-0 right-0 z-[90] flex items-center justify-between gap-4 border-t px-4 py-2.5 backdrop-blur-md"
  style="border-color: var(--border); background-color: color-mix(in srgb, var(--bg) 88%, transparent); padding-bottom: max(0.625rem, env(safe-area-inset-bottom));"
  aria-label="Social e lingua"
>
  <!-- Lingua -->
  <LangSelector currentLang={lang} />

  <!-- Social links -->
  <div class="flex items-center gap-1.5">
    <span class="social-sticky-label">{t('social_label')}</span>
    <div class="flex items-center gap-4">
      {SOCIAL_LINKS.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={link.label}
          title={link.label}
          class="social-sticky-link"
        >
          <img src={link.icon} alt="" width="36" height="36" loading="lazy" decoding="async" />
        </a>
      ))}
    </div>
  </div>
</nav>

<style>
  .social-sticky-label {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold);
    white-space: nowrap;
    padding-right: 0.6rem;
    border-right: 1px solid var(--border);
    margin-right: 0.25rem;
  }

  .social-sticky-link {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .social-sticky-link:hover {
    transform: scale(1.08);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--gold) 35%, transparent);
  }

  .social-sticky-link img {
    display: block;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 9999px;
    object-fit: cover;
  }
</style>

<style is:global>
  body.has-social-sticky {
    padding-bottom: 4.25rem;
  }
</style>

<script is:inline>
  document.body.classList.add('has-social-sticky');
</script>
