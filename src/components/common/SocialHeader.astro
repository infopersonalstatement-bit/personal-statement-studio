---
import { SOCIAL_LINKS } from '../../lib/social-links';
---

<div class="social-header pointer-events-auto hidden items-center justify-center gap-2.5 md:flex" aria-label="Seguici sui social">
  <span class="social-header-label">I Social</span>
  {SOCIAL_LINKS.map((link) => (
    <a
      href={link.href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={link.label}
      title={link.label}
      class="social-header-link"
    >
      <img src={link.icon} alt="" width="32" height="32" loading="lazy" decoding="async" />
    </a>
  ))}
</div>

<style>
  .social-header-label {
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gold);
    white-space: nowrap;
    padding-right: 0.5rem;
    border-right: 1px solid var(--border);
    margin-right: 0.25rem;
  }

  .social-header-link {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .social-header-link:hover {
    transform: scale(1.08);
    box-shadow: 0 2px 12px color-mix(in srgb, var(--gold) 35%, transparent);
  }

  .social-header-link img {
    display: block;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    object-fit: cover;
  }
</style>
