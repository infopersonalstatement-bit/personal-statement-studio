---
interface NavLink {
  href: string;
  label: string;
}

interface Props {
  eyebrow?: string;
  subtitle?: string;
  subtitleWide?: boolean;
  ctaText?: string;
  ctaHref?: string;
  ctaSecondaryText?: string;
  ctaSecondaryHref?: string;
  minHeight?: string;
  navLinks?: NavLink[];
}

const DEFAULT_NAV: NavLink[] = [
  { href: '/',          label: 'Home' },
  { href: '/manifesto', label: 'Il Manifesto' },
  { href: '/blog',      label: 'Blog' },
  { href: '/shop',      label: 'Prodotti' },
];

const {
  eyebrow,
  subtitle,
  subtitleWide = false,
  ctaText,
  ctaHref,
  ctaSecondaryText,
  ctaSecondaryHref,
  minHeight = '55vh',
  navLinks = DEFAULT_NAV,
} = Astro.props;

const pathname = Astro.url.pathname;
---

<section
  class="relative flex flex-col items-center justify-center overflow-hidden px-6 py-24 text-center"
  style={`min-height: ${minHeight};`}
>

  <!-- Gradiente oro radiale -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse 100% 80% at 50% -5%, color-mix(in srgb, var(--gold) 18%, transparent) 0%, transparent 65%);"
  ></div>

  <!-- Logo completo centrato (monogramma + testo integrato) -->
  <div class="mb-10 flex justify-center">
    <img
      src="/logo-full.png"
      alt="Personal Statement Studio"
      class="logo-full w-56 sm:w-64"
    />
  </div>

  {eyebrow && (
    <p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--text-muted);">
      {eyebrow}
    </p>
  )}

  <div class="font-display mx-auto max-w-4xl text-5xl font-light leading-[1.1] sm:text-6xl lg:text-7xl" style="color: var(--text);">
    <slot />
  </div>

  {subtitle && (
    <p
      class:list={[
        'mx-auto mt-6 text-center text-base leading-relaxed sm:text-lg',
        subtitleWide ? 'max-w-3xl' : 'max-w-xl',
      ]}
      style="color: var(--text-muted);"
    >
      {subtitle}
    </p>
  )}

  {(ctaText && ctaHref) || (ctaSecondaryText && ctaSecondaryHref) ? (
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      {ctaText && ctaHref && (
        <a href={ctaHref} class="cta-main">
          {ctaText}
        </a>
      )}
      {ctaSecondaryText && ctaSecondaryHref && (
        <a
          href={ctaSecondaryHref}
          class="inline-block rounded-full border px-8 py-3 text-xs font-semibold uppercase tracking-widest transition-all"
          style="border-color: var(--gold); color: var(--gold);"
          onmouseover="this.style.backgroundColor='var(--gold)'; this.style.color='#0F0D0A'"
          onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--gold)'"
        >
          {ctaSecondaryText}
        </a>
      )}
    </div>
  ) : null}

  <nav class="mt-10 flex flex-wrap items-center justify-center gap-3">
    {navLinks.map(link => {
      // "Home" è attiva solo se siamo esattamente su /, non su sottopagine
      const isActive = link.href === '/'
        ? pathname === '/'
        : pathname === link.href || pathname.startsWith(link.href + '/');
      return (
        <a
          href={link.href}
          class="nav-pill"
          style={isActive
            ? 'border-color: var(--gold); color: var(--gold); background-color: color-mix(in srgb, var(--gold) 8%, transparent);'
            : ''}
        >
          {link.label}
        </a>
      );
    })}
  </nav>

</section>
