---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/common/PageHero.astro';
import ScrollReveal from '../components/common/ScrollReveal.astro';
import { PROTOCOLLI, BUNDLE_HUB } from '../lib/protocolli';
import { getPageSeo } from '../lib/page-seo';

const t    = Astro.locals.t;
const lang = Astro.locals.lang ?? 'it';

const pageSeo = await getPageSeo(Astro.locals.supabase, 'manifesto', lang);

const valori = [
  { title: t('manifesto_val_01_t'), body: t('manifesto_val_01_b') },
  { title: t('manifesto_val_02_t'), body: t('manifesto_val_02_b') },
  { title: t('manifesto_val_03_t'), body: t('manifesto_val_03_b') },
  { title: t('manifesto_val_04_t'), body: t('manifesto_val_04_b') },
];

const audience = [
  t('manifesto_aud_01'),
  t('manifesto_aud_02'),
  t('manifesto_aud_03'),
  t('manifesto_aud_04'),
];
---

<BaseLayout
  title={pageSeo.seo_titolo ?? t('manifesto_eyebrow')}
  description={pageSeo.seo_descrizione ?? t('manifesto_subtitle')}
  ogImage={pageSeo.seo_og_image ?? undefined}
>

  <PageHero
    eyebrow={t('manifesto_eyebrow')}
    subtitle={t('manifesto_subtitle')}
    subtitleWide={true}
  >
    {t('manifesto_h1')}<br />
    <em class="not-italic font-semibold" style="color: var(--gold);">{t('manifesto_h1em')}</em>
  </PageHero>

  <!-- ── IL PROBLEMA ───────────────────────────────────────────────────── -->
  <section class="py-20 px-6" style="background-color: var(--bg-surface);">
    <div class="mx-auto max-w-2xl">
      <ScrollReveal>
        <p class="mb-6 text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">{t('manifesto_prob_eyebrow')}</p>
        <h2 class="font-display mb-8 text-3xl font-light leading-snug sm:text-4xl" style="color: var(--text);">
          {t('manifesto_prob_h2')}<br />
          <em class="not-italic font-semibold" style="color: var(--gold);">{t('manifesto_prob_h2em')}</em>
        </h2>
      </ScrollReveal>

      <ScrollReveal delay={120}>
        <div class="space-y-5 text-base leading-relaxed" style="color: var(--text-muted);">
          <p set:html={t('manifesto_prob_p1')} />
          <p set:html={t('manifesto_prob_p2')} />
          <p set:html={t('manifesto_prob_p3')} />
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- ── LA RISPOSTA ───────────────────────────────────────────────────── -->
  <section class="py-24 px-6">
    <div class="mx-auto max-w-3xl">
      <ScrollReveal>
        <p class="mb-6 text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">{t('manifesto_ans_eyebrow')}</p>
        <h2 class="font-display mb-8 text-3xl font-light leading-snug sm:text-4xl" style="color: var(--text);">
          {t('manifesto_ans_h2')}<br />
          <em class="not-italic font-semibold" style="color: var(--gold);">{t('manifesto_ans_h2em')}</em>
        </h2>
      </ScrollReveal>

      <ScrollReveal delay={120}>
        <p class="mb-10 text-base leading-relaxed" style="color: var(--text-muted);">
          {t('manifesto_ans_p')}
        </p>
      </ScrollReveal>

      <div class="grid gap-6 sm:grid-cols-3">
        {PROTOCOLLI.map((proto, i) => (
          <ScrollReveal delay={i * 120} class="h-full">
            <div
              class="h-full rounded-2xl border p-6"
              style="border-color: var(--border); background-color: var(--bg-card);"
            >
              <p class="mb-2 text-[10px] font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">{t('proto_label')}</p>
              <h3 class="font-display mb-2 text-xl font-light" style="color: var(--text);">{proto.nome}</h3>
              <p class="mb-3 text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
                {proto.slug === 'glow-up' ? t('proto_gup_tagline') : t('proto_di_tagline')}
              </p>
              <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
                {proto.slug === 'glow-up' ? t('proto_gup_desc') : t('proto_di_desc')}
              </p>
            </div>
          </ScrollReveal>
        ))}
        <ScrollReveal delay={240} class="h-full">
          <div
            class="h-full rounded-2xl border p-6"
            style="border-color: var(--border); background-color: color-mix(in srgb, var(--gold) 4%, var(--bg-card));"
          >
            <p class="mb-2 text-[10px] font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">{t('bundle_label')}</p>
            <h3 class="font-display mb-2 text-xl font-light" style="color: var(--text);">{BUNDLE_HUB.nome}</h3>
            <p class="mb-3 text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">{t('bundle_tagline')}</p>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">{t('bundle_desc')}</p>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- ── I VALORI ──────────────────────────────────────────────────────── -->
  <section class="py-24 px-6" style="background-color: var(--bg-surface);">
    <div class="mx-auto max-w-4xl">
      <ScrollReveal>
        <p class="mb-4 text-center text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">{t('manifesto_val_eyebrow')}</p>
        <h2 class="font-display mb-16 text-center text-3xl font-light sm:text-4xl" style="color: var(--text);">
          {t('manifesto_val_h2')}
        </h2>
      </ScrollReveal>

      <div class="grid gap-8 sm:grid-cols-2">
        {valori.map((v, i) => (
          <ScrollReveal delay={i * 100}>
            <div
              class="h-full rounded-2xl border p-7 transition-all duration-300"
              style="border-color: var(--border); background-color: var(--bg-card);"
              onmouseover="this.style.borderColor='var(--gold)'"
              onmouseout="this.style.borderColor='var(--border)'"
            >
              <h3 class="mb-3 text-sm font-semibold uppercase tracking-widest" style="color: var(--text);">{v.title}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--text-muted);">{v.body}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ── A CHI È RIVOLTO ───────────────────────────────────────────────── -->
  <section class="py-24 px-6">
    <div class="mx-auto max-w-2xl text-center">
      <ScrollReveal>
        <p class="mb-6 text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">{t('manifesto_aud_eyebrow')}</p>
        <h2 class="font-display mb-10 text-3xl font-light leading-snug sm:text-4xl" style="color: var(--text);">
          {t('manifesto_aud_h2')}<br />
          <em class="not-italic font-semibold" style="color: var(--gold);">{t('manifesto_aud_h2em')}</em>
        </h2>
      </ScrollReveal>

      <div class="mb-12 grid grid-cols-2 gap-4">
        {audience.map((cat, i) => (
          <ScrollReveal delay={i * 80}>
            <div
              class="rounded-xl border px-4 py-5 text-xs font-medium uppercase tracking-widest sm:text-sm"
              style="border-color: var(--gold); color: var(--gold);"
            >
              {cat}
            </div>
          </ScrollReveal>
        ))}
      </div>

      <ScrollReveal delay={120}>
        <p class="mb-10 text-base leading-relaxed" style="color: var(--text-muted);" set:html={t('manifesto_aud_p')} />
      </ScrollReveal>

      <ScrollReveal delay={200}>
        <a
          href="/shop"
          class="inline-block rounded-full px-10 py-4 text-sm font-semibold uppercase tracking-widest transition-all duration-200"
          style="background-color: var(--gold); color: #0F0D0A;"
          onmouseover="this.style.backgroundColor='var(--gold-hover)'"
          onmouseout="this.style.backgroundColor='var(--gold)'"
        >
          {t('home_cta')}
        </a>
      </ScrollReveal>
    </div>
  </section>

  <!-- ── FIRMA ─────────────────────────────────────────────────────────── -->
  <section class="py-20 px-6 text-center" style="background-color: var(--bg-surface);">
    <div class="mx-auto max-w-xl">
      <ScrollReveal>
        <img
          src="/logo.png"
          alt="Personal Statement Studio"
          class="mx-auto mb-8 h-24 w-auto"
          style="filter: drop-shadow(0 4px 16px color-mix(in srgb, var(--gold) 35%, transparent));"
        />
        <p class="font-display text-xl font-light italic leading-relaxed" style="color: var(--text-muted);">
          {t('manifesto_sign_quote')}
        </p>
        <p class="mt-6 text-xs uppercase tracking-[0.3em]" style="color: var(--gold);">
          {t('manifesto_sign_label')}
        </p>
      </ScrollReveal>
    </div>
  </section>

</BaseLayout>
