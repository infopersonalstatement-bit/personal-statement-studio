---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/common/PageHero.astro';
import { PROTOCOLLI, BUNDLE_HUB } from '../../lib/protocolli';

const { data: counts } = await Astro.locals.supabase
  .from('prodotti')
  .select('protocollo');

const glowCount = (counts ?? []).filter((p) => p.protocollo === 'glow-up').length;
const digitalCount = (counts ?? []).filter((p) => p.protocollo === 'digital-identity').length;

const { count: bundleCount } = await Astro.locals.supabase
  .from('bundles')
  .select('*', { count: 'exact', head: true });
---

<BaseLayout
  title="Protocolli"
  description="Glow-Up, Digital Identity e Bundle — protocolli di precisione per il business d'élite."
>
  <PageHero
    eyebrow="Personal Statement · Vault"
    subtitle="Tre percorsi. Un solo standard. Scegli il protocollo adatto al tuo obiettivo biologico o cognitivo."
    subtitleWide={true}
  >
    Accedi ai <em class="not-italic font-semibold" style="color: var(--gold);">Protocolli</em>.
  </PageHero>

  <section class="mx-auto max-w-5xl px-6 py-16 pb-28">
    <div class="grid gap-8 md:grid-cols-3">
      {PROTOCOLLI.map((proto) => {
        const count = proto.slug === 'glow-up' ? glowCount : digitalCount;
        return (
          <a
            href={proto.href}
            class="group flex flex-col rounded-2xl border p-8 transition-all duration-300"
            style="border-color: var(--border); background-color: var(--bg-card);"
            onmouseover="this.style.borderColor='var(--gold)'; this.style.transform='translateY(-3px)'"
            onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)'"
          >
            <div class="mb-5 flex justify-center">
              <img
                src={proto.icon}
                alt=""
                class="h-28 w-auto max-w-full object-contain transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            </div>
            <p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">
              Protocollo
            </p>
            <h2 class="font-display mb-2 text-3xl font-light" style="color: var(--text);">{proto.nome}</h2>
            <p class="mb-4 text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
              {proto.tagline}
            </p>
            <p class="mb-8 flex-1 text-sm leading-relaxed" style="color: var(--text-muted);">
              {proto.descrizione}
            </p>
            <p class="text-xs" style="color: var(--text-muted);">
              {count > 0 ? `${count} protocollo${count === 1 ? '' : 'i'} disponibili` : 'In arrivo'}
            </p>
            <span class="mt-4 text-xs font-semibold uppercase tracking-widest" style="color: var(--gold);">
              Esplora →
            </span>
          </a>
        );
      })}

      <a
        href={BUNDLE_HUB.href}
        class="group flex flex-col rounded-2xl border p-8 transition-all duration-300"
        style="border-color: var(--border); background-color: color-mix(in srgb, var(--gold) 4%, var(--bg-card));"
        onmouseover="this.style.borderColor='var(--gold)'; this.style.transform='translateY(-3px)'"
        onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)'"
      >
        <div class="mb-5 flex justify-center">
          <img
            src={BUNDLE_HUB.icon}
            alt=""
            class="h-28 w-auto max-w-full object-contain transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
            decoding="async"
          />
        </div>
        <p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">
          Offerta combinata
        </p>
        <h2 class="font-display mb-2 text-3xl font-light" style="color: var(--text);">{BUNDLE_HUB.nome}</h2>
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
          {BUNDLE_HUB.tagline}
        </p>
        <p class="mb-8 flex-1 text-sm leading-relaxed" style="color: var(--text-muted);">
          {BUNDLE_HUB.descrizione}
        </p>
        <p class="text-xs" style="color: var(--text-muted);">
          {(bundleCount ?? 0) > 0 ? `${bundleCount} bundle attivi` : 'Nessun bundle ancora'}
        </p>
        <span class="mt-4 text-xs font-semibold uppercase tracking-widest" style="color: var(--gold);">
          Vedi bundle →
        </span>
      </a>
    </div>
  </section>
</BaseLayout>
