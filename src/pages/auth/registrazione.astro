---
import BaseLayout from '../../layouts/BaseLayout.astro';

let errorMsg  = '';
let successMsg = '';

if (Astro.request.method === 'POST') {
  const form     = await Astro.request.formData();
  const email    = String(form.get('email') ?? '');
  const password = String(form.get('password') ?? '');
  const confirm  = String(form.get('confirm') ?? '');

  if (password !== confirm) {
    errorMsg = 'Le password non coincidono.';
  } else if (password.length < 8) {
    errorMsg = 'La password deve contenere almeno 8 caratteri.';
  } else {
    const { error } = await Astro.locals.supabase.auth.signUp({
      email,
      password,
      options: {
        // Dopo la conferma email, Supabase redirige qui
        emailRedirectTo: `${import.meta.env.PUBLIC_SITE_URL}/auth/callback`,
      },
    });

    if (error) {
      errorMsg = error.message === 'User already registered'
        ? 'Esiste già un account con questa email.'
        : 'Errore durante la registrazione. Riprova.';
    } else {
      successMsg = 'Controlla la tua email e clicca sul link di conferma per attivare l\'account.';
    }
  }
}
---

<BaseLayout title="Registrati">
  <section class="mx-auto max-w-md px-6 py-24">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">Crea account</h1>
    <p class="mb-8 text-gray-500">Inizia il tuo percorso di crescita.</p>

    {errorMsg && (
      <div class="mb-6 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-600">
        {errorMsg}
      </div>
    )}

    {successMsg ? (
      <div class="rounded-lg bg-green-50 px-4 py-6 text-center text-sm text-green-700">
        <p class="mb-1 text-base font-semibold">Email inviata!</p>
        <p>{successMsg}</p>
      </div>
    ) : (
      <form method="POST" class="space-y-4">
        <div>
          <label for="email" class="mb-1.5 block text-sm font-medium text-gray-700">
            Email
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm outline-none transition focus:border-gray-900 focus:ring-2 focus:ring-gray-900/10"
          />
        </div>

        <div>
          <label for="password" class="mb-1.5 block text-sm font-medium text-gray-700">
            Password
          </label>
          <input
            id="password"
            name="password"
            type="password"
            required
            minlength="8"
            autocomplete="new-password"
            class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm outline-none transition focus:border-gray-900 focus:ring-2 focus:ring-gray-900/10"
          />
          <p class="mt-1 text-xs text-gray-400">Minimo 8 caratteri</p>
        </div>

        <div>
          <label for="confirm" class="mb-1.5 block text-sm font-medium text-gray-700">
            Conferma password
          </label>
          <input
            id="confirm"
            name="confirm"
            type="password"
            required
            minlength="8"
            autocomplete="new-password"
            class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm outline-none transition focus:border-gray-900 focus:ring-2 focus:ring-gray-900/10"
          />
        </div>

        <button
          type="submit"
          class="w-full rounded-lg bg-gray-900 py-3 text-sm font-medium text-white transition hover:bg-gray-700"
        >
          Crea account
        </button>
      </form>
    )}

    <p class="mt-6 text-center text-sm text-gray-500">
      Hai già un account?{' '}
      <a href="/auth/login" class="font-medium text-gray-900 underline underline-offset-2">
        Accedi
      </a>
    </p>
  </section>
</BaseLayout>
