---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthCard from '../../components/auth/AuthCard.astro';
import { authCallbackUrl } from '../../lib/site';

const redirectTo = Astro.url.searchParams.get('redirect') ?? '/dashboard';
const callbackUrl = authCallbackUrl(Astro.request.url);

let errorMsg   = '';
let successMsg = '';
let pendingEmail = '';

if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData();
  const action = String(form.get('action') ?? 'signup');
  const email  = String(form.get('email') ?? '').trim().toLowerCase();

  if (action === 'resend') {
    if (!email) {
      errorMsg = 'Inserisci la tua email per rinviare il link di conferma.';
    } else {
      const { error } = await Astro.locals.supabase.auth.resend({
        type: 'signup',
        email,
        options: { emailRedirectTo: callbackUrl },
      });

      if (error) {
        console.error('[auth] resend signup:', error.message);
        errorMsg = 'Impossibile rinviare l\'email. Riprova tra qualche minuto.';
      } else {
        pendingEmail = email;
        successMsg = 'Abbiamo inviato di nuovo il link di conferma. Controlla anche la cartella spam.';
      }
    }
  } else {
    const password = String(form.get('password') ?? '');
    const confirm  = String(form.get('confirm') ?? '');

    if (password !== confirm) {
      errorMsg = 'Le password non coincidono.';
    } else if (password.length < 8) {
      errorMsg = 'La password deve contenere almeno 8 caratteri.';
    } else {
      const { data, error } = await Astro.locals.supabase.auth.signUp({
        email,
        password,
        options: { emailRedirectTo: callbackUrl },
      });

      if (error) {
        console.error('[auth] signup:', error.message);
        errorMsg = error.message === 'User already registered'
          ? 'Esiste già un account con questa email. Prova ad accedere o a rinviare la conferma.'
          : 'Errore durante la registrazione. Riprova.';
      } else if (data.session) {
        return Astro.redirect(redirectTo);
      } else if (data.user && data.user.identities?.length === 0) {
        errorMsg = 'Esiste già un account con questa email. Accedi o usa «Rinvia email» qui sotto.';
        pendingEmail = email;
      } else {
        pendingEmail = email;
        successMsg = 'Controlla la tua email e clicca sul link di conferma per attivare l\'account. Se non arriva entro qualche minuto, controlla lo spam o usa «Rinvia email».';
      }
    }
  }
}

const loginHref = redirectTo !== '/dashboard'
  ? `/auth/login?redirect=${encodeURIComponent(redirectTo)}`
  : '/auth/login';
---

<BaseLayout title="Registrati" description="Crea il tuo account Personal Statement Studio e accedi ai protocolli digitali.">
  <AuthCard title="Crea il tuo account" subtitle="Inizia il tuo percorso">

    {errorMsg && (
      <div
        class="mb-6 rounded-xl px-4 py-3 text-sm"
        style="background-color: color-mix(in srgb, #ef4444 12%, transparent); color: #ef4444; border: 1px solid color-mix(in srgb, #ef4444 30%, transparent);"
      >
        {errorMsg}
      </div>
    )}

    {successMsg ? (
      <div class="space-y-5">
        <div
          class="rounded-xl px-5 py-6 text-center text-sm"
          style="background-color: color-mix(in srgb, #22c55e 10%, transparent); color: #4ade80; border: 1px solid color-mix(in srgb, #22c55e 25%, transparent);"
        >
          <p class="mb-2 text-base font-semibold" style="color: var(--text);">Email inviata!</p>
          <p style="color: var(--text-muted);">{successMsg}</p>
          {pendingEmail && (
            <p class="mt-3 text-xs" style="color: var(--text-muted);">Inviata a <strong style="color: var(--text);">{pendingEmail}</strong></p>
          )}
        </div>

        <form method="POST" class="space-y-3">
          <input type="hidden" name="action" value="resend" />
          <input type="hidden" name="email" value={pendingEmail} />
          <button type="submit" class="auth-submit w-full">
            Rinvia email di conferma
          </button>
        </form>
      </div>
    ) : (
      <form method="POST" class="space-y-4">
        <div>
          <label for="email" class="mb-1.5 block text-xs font-medium uppercase tracking-wider" style="color: var(--text-muted);">
            Email
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="auth-input"
          />
        </div>

        <div>
          <label for="password" class="mb-1.5 block text-xs font-medium uppercase tracking-wider" style="color: var(--text-muted);">
            Password
          </label>
          <input
            id="password"
            name="password"
            type="password"
            required
            minlength="8"
            autocomplete="new-password"
            class="auth-input"
          />
          <p class="mt-1.5 text-xs" style="color: var(--text-muted);">Minimo 8 caratteri</p>
        </div>

        <div>
          <label for="confirm" class="mb-1.5 block text-xs font-medium uppercase tracking-wider" style="color: var(--text-muted);">
            Conferma password
          </label>
          <input
            id="confirm"
            name="confirm"
            type="password"
            required
            minlength="8"
            autocomplete="new-password"
            class="auth-input"
          />
        </div>

        <button type="submit" class="auth-submit">
          Crea account
        </button>
      </form>
    )}

    {!successMsg && errorMsg && pendingEmail && (
      <form method="POST" class="mt-4 space-y-3">
        <input type="hidden" name="action" value="resend" />
        <input type="hidden" name="email" value={pendingEmail} />
        <button type="submit" class="oauth-btn w-full">
          Rinvia email di conferma
        </button>
      </form>
    )}

    <p class="mt-6 text-center text-sm" style="color: var(--text-muted);">
      Hai già un account?{' '}
      <a href={loginHref} class="font-medium underline underline-offset-2 transition-colors" style="color: var(--gold);">
        Accedi
      </a>
    </p>

  </AuthCard>
</BaseLayout>
