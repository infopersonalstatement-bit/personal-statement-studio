---
export const prerender = false;

const reqUrl      = new URL(Astro.request.url);
const code        = reqUrl.searchParams.get('code');
const next        = reqUrl.searchParams.get('next') ?? null;

if (code) {
  const { data, error } = await Astro.locals.supabase.auth.exchangeCodeForSession(code);

  if (!error && data.user) {
    if (next) return Astro.redirect(next);

    const { data: profile } = await Astro.locals.supabase
      .from('utenti')
      .select('ruolo')
      .eq('id', data.user.id)
      .single();

    const dest = profile?.ruolo === 'admin' ? '/admin' : '/dashboard';
    return Astro.redirect(dest);
  }
}

return Astro.redirect('/auth/login?error=callback_failed');
---
