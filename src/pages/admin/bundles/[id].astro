---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createSupabaseAdminClient } from '../../../lib/supabase/server';
import SeoFields from '../../../components/admin/SeoFields.astro';

const supabase = createSupabaseAdminClient();
const { id } = Astro.params;

let successMsg = Astro.url.searchParams.get('ok') === '1'
  ? 'Bundle aggiornato con successo!'
  : '';

const [
  { data: bundle, error: fetchErr },
  { data: prodotti },
] = await Promise.all([
  supabase.from('bundles')
    .select('id, nome, prezzo, prezzo_originale, descrizione, anteprima, slug, seo_titolo, seo_descrizione, seo_og_image')
    .eq('id', id).single(),
  supabase.from('prodotti').select('id, nome, prezzo, protocollo').order('nome'),
]);

if (fetchErr || !bundle) return Astro.redirect('/admin/bundles');

const { data: bundleItems } = await supabase
  .from('bundle_prodotti')
  .select('prodotto_id')
  .eq('bundle_id', id);

const selectedIds = new Set((bundleItems ?? []).map((r: any) => r.prodotto_id));
const anteprimaEsistente = bundle.anteprima ?? '';
const descrizioneEsistente = bundle.descrizione ?? '';

function protocolloLabel(slug: string | null) {
  if (slug === 'glow-up') return 'Glow-Up';
  if (slug === 'digital-identity') return 'Digital Identity';
  return '';
}
---

<AdminLayout title={`Modifica: ${bundle.nome}`} activeNav="bundles">

  <div class="mb-6">
    <a href="/admin/bundles" class="text-xs uppercase tracking-widest transition-colors" style="color: var(--text-muted);"
      onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--text-muted)'">
      ← Torna ai bundle
    </a>
  </div>

  {successMsg && (
    <div class="mb-6 rounded-xl border border-green-600/40 bg-green-600/10 px-5 py-3 text-sm text-green-400">{successMsg}</div>
  )}

  <section class="rounded-2xl border p-8" style="border-color: var(--border); background-color: color-mix(in srgb, var(--surface) 40%, transparent);">
    <form id="form-modifica-bundle" class="space-y-5">

      <div class="grid gap-5 sm:grid-cols-3">
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">Nome bundle *</label>
          <input type="text" name="nome" required value={bundle.nome} class="auth-input w-full" />
        </div>
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">Prezzo bundle (€) *</label>
          <input type="number" name="prezzo" required min="0.01" step="0.01"
            value={Number(bundle.prezzo).toFixed(2)} class="auth-input w-full" />
        </div>
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
            Prezzo originale (€) <span class="normal-case font-normal">— barrato</span>
          </label>
          <input type="number" name="prezzo_originale" min="0.01" step="0.01"
            value={bundle.prezzo_originale ? Number(bundle.prezzo_originale).toFixed(2) : ''}
            placeholder="129.00" class="auth-input w-full" />
        </div>
      </div>

      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
          Descrizione breve
        </label>
        <textarea name="descrizione" rows="2" class="auth-input w-full resize-y">{descrizioneEsistente}</textarea>
      </div>

      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
          Testo di vendita
        </label>
        <div id="editor-anteprima" style="min-height: 220px;"></div>
      </div>

      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
          Prodotti inclusi * <span class="normal-case">(minimo 2)</span>
        </label>
        <div class="max-h-64 overflow-y-auto rounded-xl border p-4" style="border-color: var(--border); background-color: var(--bg);">
          <div class="space-y-2">
            {(prodotti ?? []).map((p: any) => (
              <label class="flex cursor-pointer items-center gap-3 rounded-lg border px-3 py-2 text-sm transition-colors"
                style={`border-color:${selectedIds.has(p.id) ? 'var(--gold)' : 'var(--border)'};`}
                id={`prod-lbl-${p.id}`}>
                <input type="checkbox" name="prodotto_ids" value={p.id} checked={selectedIds.has(p.id)} class="rounded"
                  onchange={`var l=document.getElementById('prod-lbl-${p.id}');l.style.borderColor=this.checked?'var(--gold)':'var(--border)';`} />
                <span style="color: var(--text);">{p.nome}</span>
                <span class="text-xs" style="color: var(--text-muted);">
                  {protocolloLabel(p.protocollo)} · €{Number(p.prezzo).toFixed(2)}
                </span>
              </label>
            ))}
          </div>
        </div>
      </div>

      <SeoFields
        seoTitolo={bundle.seo_titolo ?? ''}
        seoDescrizione={bundle.seo_descrizione ?? ''}
        seoOgImage={bundle.seo_og_image ?? ''}
        slug={bundle.slug ?? ''}
      />

      <div class="pt-2">
        <button type="submit" id="btn-salva-bundle" class="auth-submit">Salva modifiche</button>
        <p id="modifica-bundle-msg" class="mt-3 hidden text-sm"></p>
      </div>
    </form>
  </section>

</AdminLayout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
<script is:inline define:vars={{ anteprimaEsistente, bundleId: id }}>
(function () {
  const toolbarOptions = [
    [{ header: [1, 2, 3, false] }],
    [{ size: ['small', false, 'large', 'huge'] }],
    ['bold', 'italic', 'underline', 'strike'],
    [{ color: [] }, { background: [] }],
    [{ list: 'ordered' }, { list: 'bullet' }],
    ['blockquote', 'link'],
    ['clean'],
  ];

  const quill = new Quill('#editor-anteprima', {
    theme: 'snow',
    modules: { toolbar: toolbarOptions },
  });

  if (anteprimaEsistente) {
    quill.root.innerHTML = anteprimaEsistente;
  }

  function toB64(str) {
    return btoa(unescape(encodeURIComponent(str)));
  }

  function fileExt(name) {
    return (name.split('.').pop() || 'jpg').toLowerCase();
  }

  function fileToB64(file) {
    return new Promise(function(resolve, reject) {
      var reader = new FileReader();
      reader.onload = function() { resolve(String(reader.result).split(',')[1]); };
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  async function parseApiResponse(res) {
    var text = await res.text();
    try { return { ok: res.ok, data: JSON.parse(text) }; }
    catch (e) {
      throw new Error(res.status === 403 ? 'Bloccato dal firewall Vercel — riprova tra poco' : (text.slice(0, 120) || 'Errore server'));
    }
  }

  const form = document.getElementById('form-modifica-bundle');
  const msgEl = document.getElementById('modifica-bundle-msg');
  const btn = document.getElementById('btn-salva-bundle');

  if (form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      const nome = form.querySelector('input[name="nome"]')?.value?.trim();
      const prezzo = parseFloat(form.querySelector('input[name="prezzo"]')?.value);
      const prodottoIds = Array.from(form.querySelectorAll('input[name="prodotto_ids"]:checked')).map(function(el) { return el.value; });

      if (!nome || isNaN(prezzo) || prezzo <= 0) {
        if (msgEl) { msgEl.style.color = '#ef4444'; msgEl.textContent = 'Nome e prezzo (> 0) sono obbligatori.'; msgEl.classList.remove('hidden'); }
        return;
      }
      if (prodottoIds.length < 2) {
        if (msgEl) { msgEl.style.color = '#ef4444'; msgEl.textContent = 'Seleziona almeno 2 prodotti.'; msgEl.classList.remove('hidden'); }
        return;
      }

      if (btn) { btn.disabled = true; btn.textContent = 'Salvataggio…'; }
      if (msgEl) { msgEl.style.color = 'var(--text-muted)'; msgEl.textContent = 'Salvataggio in corso…'; msgEl.classList.remove('hidden'); }

      try {
        const ogFile = form.querySelector('input[name="seo_og_image_file"]')?.files?.[0];
        const uploadPanel = document.getElementById('og-panel-upload');
        const isUploadTab = uploadPanel && !uploadPanel.classList.contains('hidden');
        let ogImageB64 = null;
        let ogImageExt = null;
        if (isUploadTab && ogFile && ogFile.size > 0) {
          ogImageB64 = await fileToB64(ogFile);
          ogImageExt = fileExt(ogFile.name);
        }

        const html = quill.root.innerHTML;
        const anteprima = html === '<p><br></p>' ? '' : html;

        const res = await fetch('/api/admin/bundles', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            action: 'aggiorna',
            id: bundleId,
            nome,
            descrizione: form.querySelector('textarea[name="descrizione"]')?.value?.trim() || null,
            anteprima_b64: anteprima ? toB64(anteprima) : null,
            prezzo,
            prezzo_originale: form.querySelector('input[name="prezzo_originale"]')?.value?.trim() || null,
            slug: form.querySelector('input[name="slug"]')?.value?.trim() || null,
            seo_titolo: form.querySelector('input[name="seo_titolo"]')?.value?.trim() || null,
            seo_descrizione: form.querySelector('textarea[name="seo_descrizione"]')?.value?.trim() || null,
            seo_og_image: form.querySelector('input[name="seo_og_image_url"]')?.value?.trim() || null,
            og_image_b64: ogImageB64,
            og_image_ext: ogImageExt,
            prodotto_ids: prodottoIds,
          }),
        });

        const { ok, data } = await parseApiResponse(res);
        if (!ok) throw new Error(data.error || 'Errore salvataggio');

        window.location.href = window.location.pathname + '?ok=1';
      } catch (err) {
        if (msgEl) { msgEl.style.color = '#ef4444'; msgEl.textContent = '✗ ' + (err.message || 'Errore'); msgEl.classList.remove('hidden'); }
        if (btn) { btn.disabled = false; btn.textContent = 'Salva modifiche'; }
      }
    });
  }
})();
</script>
