---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { createSupabaseAdminClient } from '../../lib/supabase/server';
import SeoFields from '../../components/admin/SeoFields.astro';
import CategoryTagFields from '../../components/admin/CategoryTagFields.astro';
import ProtocolloSelect from '../../components/admin/ProtocolloSelect.astro';

const supabase = createSupabaseAdminClient();

let successMsg = Astro.url.searchParams.get('ok') === '1'
  ? 'Prodotto creato con successo!'
  : '';
let errorMsg = '';

const [
  { data: prodotti, error: listErr },
  { data: categorie },
  { data: tagDisponibili },
] = await Promise.all([
  supabase
    .from('prodotti')
    .select('id, nome, prezzo, descrizione, slug, protocollo, created_at')
    .order('created_at', { ascending: false }),
  supabase.from('categorie').select('id, nome').in('tipo', ['shop', 'both']).order('nome'),
  supabase.from('tag').select('id, nome').in('tipo', ['shop', 'both']).order('nome'),
]);
---

<AdminLayout title="Prodotti & PDF" activeNav="prodotti">

  <!-- Feedback -->
  {successMsg && (
    <div class="mb-6 rounded-xl border border-green-600/40 bg-green-600/10 px-5 py-3 text-sm text-green-400">{successMsg}</div>
  )}
  {errorMsg && (
    <div class="mb-6 rounded-xl border border-red-600/40 bg-red-600/10 px-5 py-3 text-sm text-red-400">{errorMsg}</div>
  )}

  <!-- Form crea nuovo prodotto -->
  <section class="mb-14 rounded-2xl border p-8" style="border-color: var(--border); background-color: color-mix(in srgb, var(--surface) 40%, transparent);">
    <h2 class="mb-6 font-display text-2xl font-light" style="color: var(--text);">Crea nuovo prodotto</h2>
    <form id="form-crea-prodotto" class="space-y-5">

      <div class="grid gap-5 sm:grid-cols-3">
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
            Nome prodotto *
          </label>
          <input
            type="text"
            name="nome"
            required
            placeholder="Es. Guida alla Chiarezza Mentale"
            class="auth-input w-full"
          />
        </div>
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
            Prezzo (€) *
          </label>
          <input
            type="number"
            name="prezzo"
            required
            min="0.01"
            step="0.01"
            placeholder="29.00"
            class="auth-input w-full"
          />
        </div>
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
            Prezzo originale (€) <span class="normal-case font-normal" style="color:var(--text-muted);">— barrato, opzionale</span>
          </label>
          <input
            type="number"
            name="prezzo_originale"
            min="0.01"
            step="0.01"
            placeholder="49.00"
            class="auth-input w-full"
          />
          <p class="mt-1 text-xs" style="color:var(--text-muted);">Inserisci solo se vuoi mostrare uno sconto. Deve essere maggiore del prezzo attuale.</p>
        </div>
      </div>

      <ProtocolloSelect />

      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
          Descrizione breve <span class="normal-case" style="color:var(--text-muted);">(appare sulle card)</span>
        </label>
        <textarea
          name="descrizione"
          rows="2"
          placeholder="Una riga che cattura l'essenza del prodotto…"
          class="auth-input w-full resize-y"
        ></textarea>
      </div>

      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
          Anteprima pubblica <span class="normal-case" style="color:var(--text-muted);">(visibile a tutti nella pagina prodotto)</span>
        </label>
        <!-- Editor WYSIWYG -->
        <div id="editor-anteprima" style="min-height: 220px;"></div>
        <p class="mt-1 text-xs" style="color:var(--text-muted);">Usa la barra in alto per formattare il testo — il risultato sarà mostrato come anteprima prima dell'acquisto.</p>
      </div>

      <!-- PDF Italiano (obbligatorio) -->
      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
          PDF 🇮🇹 Italiano * <span class="normal-case" style="color:var(--text-muted);">(obbligatorio — verrà salvato in modo sicuro)</span>
        </label>
        <div
          class="flex items-center gap-4 rounded-xl border-2 border-dashed px-5 py-6 transition-colors duration-200"
          style="border-color: var(--border);"
          id="dropzone"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--gold)">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
          </svg>
          <div class="flex-1">
            <p class="text-sm" style="color:var(--text);">Versione italiana del protocollo</p>
            <p class="text-xs" style="color:var(--text-muted);">Solo file .pdf · Max 200MB</p>
          </div>
          <input
            type="file"
            name="pdf"
            accept=".pdf,application/pdf"
            required
            id="pdf-input"
            class="absolute opacity-0"
            style="width:1px; height:1px;"
          />
          <label
            for="pdf-input"
            class="cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-widest transition-all duration-200"
            style="background-color: var(--gold); color: #0F0D0A;"
          >
            Scegli file
          </label>
        </div>
        <p id="pdf-filename" class="mt-1.5 text-xs" style="color:var(--gold);"></p>
      </div>

      <!-- PDF Inglese (opzionale) -->
      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
          PDF 🇬🇧 English <span class="normal-case" style="color:var(--text-muted);">(opzionale — stessa guida in inglese)</span>
        </label>
        <div
          class="flex items-center gap-4 rounded-xl border-2 border-dashed px-5 py-6 transition-colors duration-200"
          style="border-color: var(--border);"
          id="dropzone-en"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--text-muted)">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
          </svg>
          <div class="flex-1">
            <p class="text-sm" style="color:var(--text);">Versione inglese del protocollo</p>
            <p class="text-xs" style="color:var(--text-muted);">Solo file .pdf · Max 200MB</p>
          </div>
          <input
            type="file"
            name="pdf_en"
            accept=".pdf,application/pdf"
            id="pdf-en-input"
            class="absolute opacity-0"
            style="width:1px; height:1px;"
          />
          <label
            for="pdf-en-input"
            class="cursor-pointer rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-widest transition-all duration-200"
            style="border-color: var(--border); color: var(--text-muted);"
            onmouseover="this.style.borderColor='var(--gold)'; this.style.color='var(--gold)'"
            onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-muted)'"
          >
            Scegli file
          </label>
        </div>
        <p id="pdf-en-filename" class="mt-1.5 text-xs" style="color:var(--gold);"></p>
      </div>

      <CategoryTagFields
        tipo="shop"
        categorie={categorie ?? []}
        tagDisponibili={tagDisponibili ?? []}
      />

      <SeoFields />

      <div class="pt-2">
        <button type="submit" id="btn-salva-prodotto" class="auth-submit">
          Carica e pubblica prodotto
        </button>
        <p id="crea-prodotto-msg" class="mt-3 hidden text-sm"></p>
      </div>
    </form>
  </section>

  <!-- Lista prodotti esistenti -->
  <section>
    <h2 class="mb-5 font-display text-2xl font-light" style="color: var(--text);">Prodotti pubblicati</h2>

    {listErr && (
      <p class="text-sm text-red-400">Errore caricamento: {listErr.message}</p>
    )}

    {prodotti && prodotti.length > 0 ? (
      <div class="overflow-x-auto rounded-2xl border" style="border-color: var(--border);">
        <table class="w-full text-sm">
          <thead>
            <tr style="border-bottom: 1px solid var(--border); background-color: color-mix(in srgb, var(--surface) 60%, transparent);">
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">Nome</th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">Protocollo</th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">Prezzo</th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">Creato</th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">Azioni</th>
            </tr>
          </thead>
          <tbody>
            {prodotti.map((p: any) => (
              <tr style="border-bottom: 1px solid var(--border);">
                <td class="px-5 py-4">
                  <p class="font-medium" style="color: var(--text);">{p.nome}</p>
                  {p.descrizione && (
                    <p class="mt-0.5 text-xs line-clamp-1" style="color: var(--text-muted);">{p.descrizione}</p>
                  )}
                  <a
                    href={`/shop/${p.slug ?? p.id}`}
                    target="_blank"
                    class="mt-1 inline-block text-xs"
                    style="color: var(--gold); opacity: 0.7;"
                    onmouseover="this.style.opacity='1'"
                    onmouseout="this.style.opacity='0.7'"
                  >
                    /shop/{p.slug ?? p.id} ↗
                  </a>
                </td>
                <td class="px-5 py-4 text-xs" style="color: var(--text-muted);">
                  {p.protocollo === 'glow-up' ? 'Glow-Up' : p.protocollo === 'digital-identity' ? 'Digital Identity' : '—'}
                </td>
                <td class="px-5 py-4 font-semibold" style="color: var(--gold);">€{Number(p.prezzo).toFixed(2)}</td>
                <td class="px-5 py-4 text-xs" style="color: var(--text-muted);">
                  {new Date(p.created_at).toLocaleDateString('it-IT', { day: '2-digit', month: 'short', year: 'numeric' })}
                </td>
                <td class="px-5 py-4">
                  <div class="flex flex-wrap gap-2">
                    <a
                      href={`/admin/prodotti/${p.id}`}
                      class="rounded-full border px-3 py-1 text-xs transition-all duration-200"
                      style="border-color: var(--border); color: var(--text-muted);"
                      onmouseover="this.style.borderColor='var(--gold)'; this.style.color='var(--gold)'"
                      onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-muted)'"
                    >
                      Modifica
                    </a>
                    <button
                      type="button"
                      class="btn-traduci rounded-full border px-3 py-1 text-xs transition-all duration-200"
                      data-id={p.id}
                      data-type="prodotto"
                      style="border-color: var(--border); color: var(--text-muted);"
                      onmouseover="this.style.borderColor='#7c6ff7'; this.style.color='#7c6ff7'"
                      onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-muted)'"
                      title="Genera traduzioni EN, FR, ES, DE con GPT"
                    >
                      🌐 Traduci
                    </button>
                    <button
                      type="button"
                      class="btn-elimina-prodotto rounded-full border px-3 py-1 text-xs transition-all duration-200"
                      data-id={p.id}
                      style="border-color: var(--border); color: var(--text-muted);"
                      onmouseover="this.style.borderColor='#ef4444'; this.style.color='#ef4444'"
                      onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-muted)'"
                    >
                      Elimina
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <p class="text-sm" style="color: var(--text-muted);">Nessun prodotto ancora pubblicato.</p>
    )}
  </section>

</AdminLayout>

<script>
  const input = document.getElementById('pdf-input') as HTMLInputElement;
  const label = document.getElementById('pdf-filename') as HTMLParagraphElement;
  if (input && label) {
    input.addEventListener('change', () => {
      const file = input.files?.[0];
      label.textContent = file ? `✔ ${file.name} (${(file.size / 1024 / 1024).toFixed(1)} MB)` : '';
    });
  }
  const inputEn = document.getElementById('pdf-en-input') as HTMLInputElement;
  const labelEn = document.getElementById('pdf-en-filename') as HTMLParagraphElement;
  if (inputEn && labelEn) {
    inputEn.addEventListener('change', () => {
      const file = inputEn.files?.[0];
      labelEn.textContent = file ? `✔ ${file.name} (${(file.size / 1024 / 1024).toFixed(1)} MB)` : '';
    });
  }
</script>

<!-- Quill WYSIWYG -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
<script is:inline>
(function () {
  const toolbarOptions = [
    [{ header: [1, 2, 3, false] }],
    [{ size: ['small', false, 'large', 'huge'] }],
    ['bold', 'italic', 'underline', 'strike'],
    [{ color: [] }, { background: [] }],
    [{ list: 'ordered' }, { list: 'bullet' }],
    ['blockquote', 'link'],
    ['clean'],
  ];

  const quill = new Quill('#editor-anteprima', {
    theme: 'snow',
    placeholder: 'Scrivi qui l\'anteprima del prodotto…',
    modules: { toolbar: toolbarOptions },
  });

  function toB64(str) {
    return btoa(unescape(encodeURIComponent(str)));
  }

  function fileExt(name) {
    return (name.split('.').pop() || 'jpg').toLowerCase();
  }

  function fileToB64(file) {
    return new Promise(function(resolve, reject) {
      var reader = new FileReader();
      reader.onload = function() { resolve(String(reader.result).split(',')[1]); };
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  async function parseApiResponse(res) {
    var text = await res.text();
    try { return { ok: res.ok, data: JSON.parse(text) }; }
    catch (e) {
      throw new Error(res.status === 403 ? 'Bloccato dal firewall Vercel — riprova tra poco' : (text.slice(0, 120) || 'Errore server'));
    }
  }

  const form = document.getElementById('form-crea-prodotto');
  const msgEl = document.getElementById('crea-prodotto-msg');
  const btn = document.getElementById('btn-salva-prodotto');

  if (form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      const nome = form.querySelector('input[name="nome"]').value.trim();
      const prezzo = parseFloat(form.querySelector('input[name="prezzo"]').value);
      const pdfFile = document.getElementById('pdf-input').files[0];
      const pdfEnFile = document.getElementById('pdf-en-input').files[0] || null;

      if (!nome || isNaN(prezzo) || prezzo <= 0) {
        if (msgEl) { msgEl.style.color = '#ef4444'; msgEl.textContent = 'Nome e prezzo (> 0) sono obbligatori.'; msgEl.classList.remove('hidden'); }
        return;
      }
      if (!pdfFile) {
        if (msgEl) { msgEl.style.color = '#ef4444'; msgEl.textContent = 'Carica il PDF in italiano (obbligatorio).'; msgEl.classList.remove('hidden'); }
        return;
      }

      if (btn) { btn.disabled = true; btn.textContent = 'Caricamento…'; }
      if (msgEl) { msgEl.style.color = 'var(--text-muted)'; msgEl.textContent = 'Preparazione file…'; msgEl.classList.remove('hidden'); }

      try {
        // ── Step 1a: signed URL per PDF italiano ──
        if (msgEl) msgEl.textContent = 'Upload PDF italiano…';
        const urlRes = await fetch('/api/admin/upload-pdf', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ nome, suffix: 'it' }),
        });
        const urlData = await urlRes.json();
        if (!urlRes.ok) throw new Error(urlData.error || 'Errore generazione URL upload');

        // ── Step 1b: upload PDF italiano su Supabase Storage ──
        if (msgEl) msgEl.textContent = 'Upload PDF IT (' + Math.round(pdfFile.size / 1024) + ' KB)…';
        const uploadRes = await fetch(urlData.signed_url, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/pdf' },
          body: pdfFile,
        });
        if (!uploadRes.ok) {
          const uploadErr = await uploadRes.text().catch(() => '');
          throw new Error('Errore upload PDF IT: ' + (uploadErr.slice(0, 100) || uploadRes.status));
        }
        const pdfFilePath = urlData.path;

        // ── Step 1c: PDF inglese (opzionale) ──
        let pdfEnFilePath = null;
        if (pdfEnFile) {
          if (msgEl) msgEl.textContent = 'Upload PDF inglese…';
          const urlResEn = await fetch('/api/admin/upload-pdf', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ nome, suffix: 'en' }),
          });
          const urlDataEn = await urlResEn.json();
          if (!urlResEn.ok) throw new Error(urlDataEn.error || 'Errore URL upload PDF EN');

          if (msgEl) msgEl.textContent = 'Upload PDF EN (' + Math.round(pdfEnFile.size / 1024) + ' KB)…';
          const uploadResEn = await fetch(urlDataEn.signed_url, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/pdf' },
            body: pdfEnFile,
          });
          if (!uploadResEn.ok) {
            const uploadErrEn = await uploadResEn.text().catch(() => '');
            throw new Error('Errore upload PDF EN: ' + (uploadErrEn.slice(0, 100) || uploadResEn.status));
          }
          pdfEnFilePath = urlDataEn.path;
        }

        // ── Step 2: OG image (base64, piccola — max 5MB) ──
        const ogFile = form.querySelector('input[name="seo_og_image_file"]')?.files?.[0];
        const uploadPanel = document.getElementById('og-panel-upload');
        const isUploadTab = uploadPanel && !uploadPanel.classList.contains('hidden');
        let ogImageB64 = null;
        let ogImageExt = null;
        if (isUploadTab && ogFile && ogFile.size > 0) {
          ogImageB64 = await fileToB64(ogFile);
          ogImageExt = fileExt(ogFile.name);
        }

        if (msgEl) msgEl.textContent = 'Salvataggio prodotto…';

        const html = quill.root.innerHTML;
        const anteprima = html === '<p><br></p>' ? '' : html;
        const tagIds = Array.from(form.querySelectorAll('input[name="tag_ids"]:checked')).map(function(el) { return el.value; });

        const res = await fetch('/api/admin/prodotti', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            action: 'crea',
            nome,
            descrizione: form.querySelector('textarea[name="descrizione"]')?.value?.trim() || null,
            anteprima_b64: anteprima ? toB64(anteprima) : null,
            prezzo,
            prezzo_originale: form.querySelector('input[name="prezzo_originale"]')?.value?.trim() || null,
            slug: form.querySelector('input[name="slug"]')?.value?.trim() || null,
            seo_titolo: form.querySelector('input[name="seo_titolo"]')?.value?.trim() || null,
            seo_descrizione: form.querySelector('textarea[name="seo_descrizione"]')?.value?.trim() || null,
            seo_og_image: form.querySelector('input[name="seo_og_image_url"]')?.value?.trim() || null,
            og_image_b64: ogImageB64,
            og_image_ext: ogImageExt,
            file_path: pdfFilePath,
            file_path_en: pdfEnFilePath,
            protocollo: form.querySelector('select[name="protocollo"]')?.value?.trim() || null,
            categoria_id: form.querySelector('select[name="categoria_id"]')?.value?.trim() || null,
            tag_ids: tagIds,
          }),
        });

        const { ok, data } = await parseApiResponse(res);
        if (!ok) throw new Error(data.error || 'Errore salvataggio');

        window.location.href = '/admin/prodotti?ok=1';
      } catch (err) {
        if (msgEl) { msgEl.style.color = '#ef4444'; msgEl.textContent = '✗ ' + (err.message || 'Errore'); msgEl.classList.remove('hidden'); }
        if (btn) { btn.disabled = false; btn.textContent = 'Carica e pubblica prodotto'; }
      }
    });
  }

  // Traduci contenuto via GPT
  document.querySelectorAll('.btn-traduci').forEach(function(el) {
    el.addEventListener('click', async function() {
      const id   = el.getAttribute('data-id');
      const type = el.getAttribute('data-type');
      const origText = el.textContent;
      el.disabled = true;
      el.textContent = '⏳ Traduzione…';
      try {
        const res = await fetch('/api/admin/translate-content', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ entity_id: id, entity_type: type }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Errore');
        el.textContent = '✔ Tradotto';
        el.style.borderColor = '#22c55e';
        el.style.color = '#22c55e';
        setTimeout(function() {
          el.textContent = origText;
          el.style.borderColor = '';
          el.style.color = '';
          el.disabled = false;
        }, 3000);
      } catch(err) {
        el.textContent = '✗ ' + (err.message || 'Errore');
        el.style.color = '#ef4444';
        setTimeout(function() {
          el.textContent = origText;
          el.style.color = '';
          el.disabled = false;
        }, 4000);
      }
    });
  });

  // Elimina prodotto via API
  document.querySelectorAll('.btn-elimina-prodotto').forEach(function(el) {
    el.addEventListener('click', async function() {
      if (!confirm('Eliminare definitivamente questo prodotto?')) return;
      const id = el.getAttribute('data-id');
      const res = await fetch('/api/admin/prodotti', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'elimina', id }),
      });
      const { ok, data } = await parseApiResponse(res);
      if (ok) window.location.reload();
      else alert('Errore: ' + (data.error || 'sconosciuto'));
    });
  });
})();
</script>

