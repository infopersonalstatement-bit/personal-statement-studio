---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { createSupabaseAdminClient } from '../../lib/supabase/server';
import SeoFields from '../../components/admin/SeoFields.astro';
import CategoryTagFields from '../../components/admin/CategoryTagFields.astro';

const supabase = createSupabaseAdminClient();

let successMsg = Astro.url.searchParams.get('ok') === '1'
  ? 'Articolo salvato con successo!'
  : '';
let errorMsg = '';

const [
  { data: articoli, error: listErr },
  { data: categorie },
  { data: tagDisponibili },
] = await Promise.all([
  supabase
    .from('articoli')
    .select('id, titolo, slug, estratto, pubblicato, created_at')
    .order('created_at', { ascending: false }),
  supabase.from('categorie').select('id, nome').in('tipo', ['blog', 'both']).order('nome'),
  supabase.from('tag').select('id, nome').in('tipo', ['blog', 'both']).order('nome'),
]);
---

<AdminLayout title="Blog" activeNav="blog">

  <!-- Feedback -->
  {successMsg && (
    <div class="mb-6 rounded-xl border border-green-600/40 bg-green-600/10 px-5 py-3 text-sm text-green-400">{successMsg}</div>
  )}
  {errorMsg && (
    <div class="mb-6 rounded-xl border border-red-600/40 bg-red-600/10 px-5 py-3 text-sm text-red-400">{errorMsg}</div>
  )}

  <!-- Form crea nuovo articolo -->
  <section class="mb-14 rounded-2xl border p-8" style="border-color: var(--border); background-color: color-mix(in srgb, var(--surface) 40%, transparent);">
    <h2 class="mb-6 font-display text-2xl font-light" style="color: var(--text);">Scrivi un nuovo articolo</h2>
    <form id="form-crea-articolo" class="space-y-5">

      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
          Titolo *
        </label>
        <input
          type="text"
          name="titolo"
          required
          placeholder="Es. Come ritrovare la chiarezza nei momenti difficili"
          class="auth-input w-full"
          id="titolo-input"
        />
        <p class="mt-1 text-xs" style="color:var(--text-muted);">
          Slug: <span id="slug-preview" class="font-mono" style="color:var(--gold);">—</span>
        </p>
      </div>

      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
          Estratto / Anteprima
        </label>
        <textarea
          name="estratto"
          rows="2"
          placeholder="Una breve descrizione che apparirà nell'elenco del blog…"
          class="auth-input w-full resize-y"
        ></textarea>
      </div>

      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
          Contenuto *
        </label>
        <!-- Editor WYSIWYG -->
        <div id="editor-contenuto" style="min-height: 360px;"></div>
      </div>

      <CategoryTagFields
        tipo="blog"
        categorie={categorie ?? []}
        tagDisponibili={tagDisponibili ?? []}
      />

      <div class="flex items-center gap-3">
        <label class="relative inline-flex cursor-pointer items-center">
          <input type="checkbox" name="pubblicato" id="pubblicato-toggle" class="sr-only peer" />
          <div
            class="h-6 w-11 rounded-full transition-all duration-200 peer-checked:bg-[color:var(--gold)]"
            style="background-color: var(--border);"
          ></div>
          <div class="absolute left-1 top-1 h-4 w-4 rounded-full bg-white transition-transform duration-200 peer-checked:translate-x-5"></div>
        </label>
        <label for="pubblicato-toggle" class="cursor-pointer text-sm" style="color: var(--text);">
          Pubblica subito (altrimenti viene salvato come bozza)
        </label>
      </div>

      <SeoFields slugPrefix="/blog/" />

      <div class="pt-2">
        <button type="submit" id="btn-salva-articolo" class="auth-submit">
          Salva articolo
        </button>
        <p id="crea-articolo-msg" class="mt-3 hidden text-sm"></p>
      </div>
    </form>
  </section>

  <!-- Lista articoli esistenti -->
  <section>
    <h2 class="mb-5 font-display text-2xl font-light" style="color: var(--text);">Articoli esistenti</h2>

    {listErr && <p class="text-sm text-red-400">Errore caricamento: {listErr.message}</p>}

    {articoli && articoli.length > 0 ? (
      <div class="space-y-4">
        {articoli.map((a: any) => (
          <div
            class="flex flex-col gap-4 rounded-2xl border p-5 sm:flex-row sm:items-start sm:justify-between transition-all duration-200"
            style="border-color: var(--border); background-color: color-mix(in srgb, var(--surface) 30%, transparent);"
          >
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-1">
                <span
                  class="rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest"
                  style={a.pubblicato
                    ? 'background-color: color-mix(in srgb, var(--gold) 15%, transparent); color: var(--gold);'
                    : 'background-color: color-mix(in srgb, var(--border) 50%, transparent); color: var(--text-muted);'}
                >
                  {a.pubblicato ? 'Pubblicato' : 'Bozza'}
                </span>
                <span class="text-xs" style="color:var(--text-muted);">
                  {new Date(a.created_at).toLocaleDateString('it-IT', { day: '2-digit', month: 'short', year: 'numeric' })}
                </span>
              </div>
              <p class="font-display text-lg font-light truncate" style="color: var(--text);">{a.titolo}</p>
              {a.estratto && (
                <p class="mt-0.5 text-sm line-clamp-1" style="color: var(--text-muted);">{a.estratto}</p>
              )}
              <p class="mt-0.5 text-xs font-mono" style="color:var(--text-muted);">/blog/{a.slug}</p>
            </div>
            <div class="flex flex-shrink-0 flex-wrap gap-2">
              <!-- Modifica -->
              <a
                href={`/admin/blog/${a.id}`}
                class="rounded-full border px-3 py-1 text-xs transition-all duration-200"
                style="border-color: var(--border); color: var(--text-muted);"
                onmouseover="this.style.borderColor='var(--gold)'; this.style.color='var(--gold)'"
                onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-muted)'"
              >
                Modifica
              </a>
              <!-- Traduci -->
              <button
                type="button"
                class="btn-traduci rounded-full border px-3 py-1 text-xs transition-all duration-200"
                data-id={a.id}
                data-type="articolo"
                style="border-color: var(--border); color: var(--text-muted);"
                onmouseover="this.style.borderColor='#7c6ff7'; this.style.color='#7c6ff7'"
                onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-muted)'"
                title="Genera traduzioni EN, FR, ES, DE con GPT"
              >
                🌐 Traduci
              </button>
              <!-- Toggle pubblica/bozza -->
              <button
                type="button"
                class="btn-toggle-pubblica rounded-full border px-3 py-1 text-xs transition-all duration-200"
                data-id={a.id}
                data-attuale={String(a.pubblicato)}
                style="border-color: var(--border); color: var(--text-muted);"
                onmouseover="this.style.borderColor='var(--gold)'; this.style.color='var(--gold)'"
                onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-muted)'"
              >
                {a.pubblicato ? 'Bozza' : 'Pubblica'}
              </button>
              <!-- Elimina -->
              <button
                type="button"
                class="btn-elimina-articolo rounded-full border px-3 py-1 text-xs transition-all duration-200"
                data-id={a.id}
                style="border-color: var(--border); color: var(--text-muted);"
                onmouseover="this.style.borderColor='#ef4444'; this.style.color='#ef4444'"
                onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-muted)'"
              >
                Elimina
              </button>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p class="text-sm" style="color: var(--text-muted);">Nessun articolo ancora scritto.</p>
    )}
  </section>

</AdminLayout>

<script>
  function slugify(text: string) {
    return text
      .toLowerCase()
      .replace(/[àáâãäå]/g, 'a')
      .replace(/[èéêë]/g, 'e')
      .replace(/[ìíîï]/g, 'i')
      .replace(/[òóôõö]/g, 'o')
      .replace(/[ùúûü]/g, 'u')
      .replace(/ç/g, 'c')
      .replace(/ñ/g, 'n')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');
  }
  const titoloInput = document.getElementById('titolo-input') as HTMLInputElement;
  const slugPreview = document.getElementById('slug-preview') as HTMLSpanElement;
  if (titoloInput && slugPreview) {
    titoloInput.addEventListener('input', () => {
      slugPreview.textContent = slugify(titoloInput.value) || '—';
    });
  }
</script>

<!-- Quill WYSIWYG -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
<script is:inline>
(function () {
  const toolbarOptions = [
    [{ header: [1, 2, 3, false] }],
    [{ size: ['small', false, 'large', 'huge'] }],
    ['bold', 'italic', 'underline', 'strike'],
    [{ color: [] }, { background: [] }],
    [{ list: 'ordered' }, { list: 'bullet' }],
    ['blockquote', 'link'],
    [{ align: [] }],
    ['clean'],
  ];

  function fileExt(name) {
    return (name.split('.').pop() || 'jpg').toLowerCase();
  }

  function fileToB64(file) {
    return new Promise(function(resolve, reject) {
      var reader = new FileReader();
      reader.onload = function() { resolve(String(reader.result).split(',')[1]); };
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  async function parseApiResponse(res) {
    var text = await res.text();
    try { return { ok: res.ok, data: JSON.parse(text) }; }
    catch (e) {
      throw new Error(res.status === 403 ? 'Bloccato dal firewall Vercel — riprova tra poco' : (text.slice(0, 120) || 'Errore server'));
    }
  }

  const quill = new Quill('#editor-contenuto', {
    theme: 'snow',
    placeholder: 'Inizia a scrivere il tuo articolo…',
    modules: { toolbar: toolbarOptions },
  });

  const form = document.getElementById('form-crea-articolo');
  const msgEl = document.getElementById('crea-articolo-msg');
  const btn = document.getElementById('btn-salva-articolo');

  if (form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      const html = quill.root.innerHTML;
      const isEmpty = html === '<p><br></p>' || html.trim() === '';

      if (isEmpty) {
        quill.root.style.border = '1px solid #ef4444';
        quill.root.focus();
        return;
      }

      if (btn) { btn.disabled = true; btn.textContent = 'Salvataggio…'; }
      if (msgEl) { msgEl.className = 'mt-3 text-sm'; msgEl.style.color = 'var(--text-muted)'; msgEl.textContent = 'Salvataggio in corso…'; msgEl.classList.remove('hidden'); }

      try {
        const ogFile = form.querySelector('input[name="seo_og_image_file"]')?.files?.[0];
        const uploadPanel = document.getElementById('og-panel-upload');
        const isUploadTab = uploadPanel && !uploadPanel.classList.contains('hidden');
        let ogImageB64 = null;
        let ogImageExt = null;
        if (isUploadTab && ogFile && ogFile.size > 0) {
          ogImageB64 = await fileToB64(ogFile);
          ogImageExt = fileExt(ogFile.name);
        }

        const titolo = form.querySelector('input[name="titolo"]')?.value?.trim();
        const estratto = form.querySelector('textarea[name="estratto"]')?.value?.trim();
        const pubblicato = form.querySelector('input[name="pubblicato"]')?.checked;
        const seoTitolo = form.querySelector('input[name="seo_titolo"]')?.value?.trim();
        const seoDesc = form.querySelector('textarea[name="seo_descrizione"]')?.value?.trim();
        const tagIds = Array.from(form.querySelectorAll('input[name="tag_ids"]:checked')).map(function(el) { return el.value; });

        const res = await fetch('/api/admin/articoli', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            titolo,
            estratto,
            pubblicato,
            seo_titolo: seoTitolo || null,
            seo_descrizione: seoDesc || null,
            seo_og_image: form.querySelector('input[name="seo_og_image_url"]')?.value?.trim() || null,
            og_image_b64: ogImageB64,
            og_image_ext: ogImageExt,
            categoria_id: form.querySelector('select[name="categoria_id"]')?.value?.trim() || null,
            tag_ids: tagIds,
            contenuto_b64: btoa(unescape(encodeURIComponent(html))),
          }),
        });

        const { ok, data } = await parseApiResponse(res);
        if (!ok) throw new Error(data.error || 'Errore salvataggio');

        window.location.href = '/admin/blog?ok=1';
      } catch (err) {
        if (msgEl) {
          msgEl.style.color = '#ef4444';
          msgEl.textContent = '✗ ' + (err.message || 'Errore imprevisto');
          msgEl.classList.remove('hidden');
        }
        if (btn) { btn.disabled = false; btn.textContent = 'Salva articolo'; }
      }
    });
  }

  document.querySelectorAll('.btn-toggle-pubblica').forEach(function(el) {
    el.addEventListener('click', async function() {
      const id = el.getAttribute('data-id');
      const attuale = el.getAttribute('data-attuale') === 'true';
      const res = await fetch('/api/admin/articoli', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'toggle-pubblica', id, attuale }),
      });
      if (res.ok) window.location.reload();
      else { const d = await res.json(); alert('Errore: ' + (d.error || 'sconosciuto')); }
    });
  });

  // Traduci contenuto via GPT
  document.querySelectorAll('.btn-traduci').forEach(function(el) {
    el.addEventListener('click', async function() {
      var id   = el.getAttribute('data-id');
      var type = el.getAttribute('data-type');
      var origText = el.textContent;
      el.disabled = true;
      el.textContent = '⏳ Traduzione…';
      try {
        var res = await fetch('/api/admin/translate-content', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ entity_id: id, entity_type: type }),
        });
        var data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Errore');
        el.textContent = '✔ Tradotto';
        el.style.borderColor = '#22c55e';
        el.style.color = '#22c55e';
        setTimeout(function() {
          el.textContent = origText;
          el.style.borderColor = '';
          el.style.color = '';
          el.disabled = false;
        }, 3000);
      } catch(err) {
        el.textContent = '✗ ' + (err.message || 'Errore');
        el.style.color = '#ef4444';
        setTimeout(function() {
          el.textContent = origText;
          el.style.color = '';
          el.disabled = false;
        }, 4000);
      }
    });
  });

  document.querySelectorAll('.btn-elimina-articolo').forEach(function(el) {
    el.addEventListener('click', async function() {
      if (!confirm('Eliminare definitivamente questo articolo?')) return;
      const id = el.getAttribute('data-id');
      const res = await fetch('/api/admin/articoli', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'elimina', id }),
      });
      if (res.ok) window.location.reload();
      else { const d = await res.json(); alert('Errore: ' + (d.error || 'sconosciuto')); }
    });
  });
})();
</script>

