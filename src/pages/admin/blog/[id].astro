---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createSupabaseAdminClient } from '../../../lib/supabase/server';
import SeoFields from '../../../components/admin/SeoFields.astro';

const supabase = createSupabaseAdminClient();
const { id }   = Astro.params;

let successMsg = Astro.url.searchParams.get('ok') === '1'
  ? 'Articolo aggiornato con successo!'
  : '';
let errorMsg   = '';

// ─── Carica articolo + categorie + tag ───────────────────────────────────────
const [
  { data: articolo, error: fetchErr },
  { data: categorie },
  { data: tagDisponibili },
] = await Promise.all([
  supabase.from('articoli')
    .select('id, titolo, slug, estratto, contenuto, pubblicato, seo_titolo, seo_descrizione, seo_og_image, categoria_id')
    .eq('id', id).single(),
  supabase.from('categorie').select('id, nome').in('tipo', ['blog','both']).order('nome'),
  supabase.from('tag').select('id, nome').in('tipo', ['blog','both']).order('nome'),
]);

if (fetchErr || !articolo) return Astro.redirect('/admin/blog');

// Tag già associati all'articolo
const { data: tagArticolo } = await supabase
  .from('articoli_tag').select('tag_id').eq('articolo_id', id);
const tagArticoloIds = new Set((tagArticolo ?? []).map((t: any) => t.tag_id));

const contenutoEsistente = articolo.contenuto ?? '';
const estrattoEsistente  = articolo.estratto  ?? '';
const titoloEsistente    = articolo.titolo    ?? '';
const pubEsistente       = articolo.pubblicato ?? false;
---

<AdminLayout title={`Modifica: ${articolo.titolo}`} activeNav="blog">

  <div class="mb-6 flex items-center gap-3">
    <a href="/admin/blog"
      class="text-xs uppercase tracking-widest transition-colors"
      style="color: var(--text-muted);"
      onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--text-muted)'">
      ← Torna al blog
    </a>
  </div>

  {successMsg && (
    <div class="mb-6 rounded-xl border border-green-600/40 bg-green-600/10 px-5 py-3 text-sm text-green-400">{successMsg}</div>
  )}
  {errorMsg && (
    <div class="mb-6 rounded-xl border border-red-600/40 bg-red-600/10 px-5 py-3 text-sm text-red-400">{errorMsg}</div>
  )}

  <section class="rounded-2xl border p-8" style="border-color: var(--border); background-color: color-mix(in srgb, var(--surface) 40%, transparent);">
    <form id="form-modifica-articolo" class="space-y-5">

      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">Titolo *</label>
        <input
          type="text"
          name="titolo"
          required
          value={titoloEsistente}
          class="auth-input w-full"
          id="titolo-input"
        />
        <p class="mt-1 text-xs" style="color:var(--text-muted);">
          URL attuale: <a href={`/blog/${articolo.slug}`} target="_blank" class="font-mono" style="color:var(--gold);">/blog/{articolo.slug}</a>
        </p>
      </div>

      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">Estratto / Anteprima</label>
        <textarea
          name="estratto"
          rows="2"
          class="auth-input w-full resize-y"
        >{estrattoEsistente}</textarea>
      </div>

      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">Contenuto *</label>
        <div id="editor-contenuto" style="min-height: 360px;"></div>
      </div>

      <!-- Categoria -->
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color:var(--text-muted);">Categoria</label>
          <select name="categoria_id" class="auth-input w-full">
            <option value="">— Nessuna categoria —</option>
            {(categorie ?? []).map((c: any) => (
              <option value={c.id} selected={articolo.categoria_id === c.id}>{c.nome}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color:var(--text-muted);">Tag</label>
          <div class="flex flex-wrap gap-2 rounded-xl border p-3" style="border-color:var(--border); background-color:var(--bg);">
            {(tagDisponibili ?? []).map((t: any) => (
              <label class="flex cursor-pointer items-center gap-1.5 rounded-full border px-2.5 py-1 text-xs transition-colors"
                style={`border-color:${tagArticoloIds.has(t.id) ? 'var(--gold)' : 'var(--border)'}; color:${tagArticoloIds.has(t.id) ? 'var(--gold)' : 'var(--text-muted)'};`}
                id={`tag-lbl-${t.id}`}>
                <input type="checkbox" name="tag_ids" value={t.id}
                  checked={tagArticoloIds.has(t.id)} class="sr-only"
                  onchange={`var l=document.getElementById('tag-lbl-${t.id}');l.style.borderColor=this.checked?'var(--gold)':'var(--border)';l.style.color=this.checked?'var(--gold)':'var(--text-muted)';`} />
                {t.nome}
              </label>
            ))}
            {(tagDisponibili ?? []).length === 0 && (
              <p class="text-xs" style="color:var(--text-muted);">Nessun tag. <a href="/admin/categorie" style="color:var(--gold);">Creane uno →</a></p>
            )}
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <label class="relative inline-flex cursor-pointer items-center">
          <input type="checkbox" name="pubblicato" id="pubblicato-toggle" class="sr-only peer"
            checked={pubEsistente} />
          <div class="h-6 w-11 rounded-full transition-all duration-200 peer-checked:bg-[color:var(--gold)]"
            style="background-color: var(--border);"></div>
          <div class="absolute left-1 top-1 h-4 w-4 rounded-full bg-white transition-transform duration-200 peer-checked:translate-x-5"></div>
        </label>
        <label for="pubblicato-toggle" class="cursor-pointer text-sm" style="color: var(--text);">
          Articolo pubblicato
        </label>
      </div>

      <SeoFields
        slug={articolo.slug ?? ''}
        slugPrefix="/blog/"
        seoTitolo={articolo.seo_titolo ?? ''}
        seoDescrizione={articolo.seo_descrizione ?? ''}
        seoOgImage={articolo.seo_og_image ?? ''}
      />

      <div class="flex gap-3 pt-2">
        <button type="submit" id="btn-salva-articolo" class="auth-submit">Salva modifiche</button>
        <p id="modifica-articolo-msg" class="hidden self-center text-sm"></p>
      </div>
    </form>
  </section>

</AdminLayout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
<script is:inline define:vars={{ contenutoEsistente, articoloId: id }}>
(function () {
  const toolbarOptions = [
    [{ header: [1, 2, 3, false] }],
    [{ size: ['small', false, 'large', 'huge'] }],
    ['bold', 'italic', 'underline', 'strike'],
    [{ color: [] }, { background: [] }],
    [{ list: 'ordered' }, { list: 'bullet' }],
    ['blockquote', 'link'],
    [{ align: [] }],
    ['clean'],
  ];

  const quill = new Quill('#editor-contenuto', {
    theme: 'snow',
    modules: { toolbar: toolbarOptions },
  });

  // Carica contenuto esistente
  if (contenutoEsistente) {
    quill.root.innerHTML = contenutoEsistente;
  }

  function toB64(str) {
    return btoa(unescape(encodeURIComponent(str)));
  }

  function fileExt(name) {
    return (name.split('.').pop() || 'jpg').toLowerCase();
  }

  function fileToB64(file) {
    return new Promise(function(resolve, reject) {
      var reader = new FileReader();
      reader.onload = function() { resolve(String(reader.result).split(',')[1]); };
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  async function parseApiResponse(res) {
    var text = await res.text();
    try { return { ok: res.ok, data: JSON.parse(text) }; }
    catch (e) {
      throw new Error(res.status === 403 ? 'Bloccato dal firewall Vercel — riprova tra poco' : (text.slice(0, 120) || 'Errore server'));
    }
  }

  const form = document.getElementById('form-modifica-articolo');
  const msgEl = document.getElementById('modifica-articolo-msg');
  const btn = document.getElementById('btn-salva-articolo');

  if (form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      const html = quill.root.innerHTML;
      const isEmpty = html === '<p><br></p>' || html.trim() === '';
      if (isEmpty) { quill.root.focus(); return; }

      if (btn) { btn.disabled = true; btn.textContent = 'Salvataggio…'; }
      if (msgEl) { msgEl.style.color = 'var(--text-muted)'; msgEl.textContent = 'Salvataggio in corso…'; msgEl.classList.remove('hidden'); }

      try {
        const ogFile = form.querySelector('input[name="seo_og_image_file"]')?.files?.[0];
        const uploadPanel = document.getElementById('og-panel-upload');
        const isUploadTab = uploadPanel && !uploadPanel.classList.contains('hidden');
        let ogImageB64 = null;
        let ogImageExt = null;
        if (isUploadTab && ogFile && ogFile.size > 0) {
          ogImageB64 = await fileToB64(ogFile);
          ogImageExt = fileExt(ogFile.name);
        }

        const tagIds = Array.from(form.querySelectorAll('input[name="tag_ids"]:checked')).map(function(el) { return el.value; });

        const res = await fetch('/api/admin/articoli', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            action: 'aggiorna',
            id: articoloId,
            titolo: form.querySelector('input[name="titolo"]')?.value?.trim(),
            estratto: form.querySelector('textarea[name="estratto"]')?.value?.trim() || null,
            pubblicato: form.querySelector('input[name="pubblicato"]')?.checked,
            seo_titolo: form.querySelector('input[name="seo_titolo"]')?.value?.trim() || null,
            seo_descrizione: form.querySelector('textarea[name="seo_descrizione"]')?.value?.trim() || null,
            seo_og_image: form.querySelector('input[name="seo_og_image_url"]')?.value?.trim() || null,
            og_image_b64: ogImageB64,
            og_image_ext: ogImageExt,
            slug: form.querySelector('input[name="slug"]')?.value?.trim() || null,
            categoria_id: form.querySelector('select[name="categoria_id"]')?.value?.trim() || null,
            tag_ids: tagIds,
            contenuto_b64: toB64(html),
          }),
        });

        const { ok, data } = await parseApiResponse(res);
        if (!ok) throw new Error(data.error || 'Errore salvataggio');

        window.location.href = window.location.pathname + '?ok=1';
      } catch (err) {
        if (msgEl) { msgEl.style.color = '#ef4444'; msgEl.textContent = '✗ ' + (err.message || 'Errore'); msgEl.classList.remove('hidden'); }
        if (btn) { btn.disabled = false; btn.textContent = 'Salva modifiche'; }
      }
    });
  }
})();
</script>
