---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createSupabaseAdminClient } from '../../../lib/supabase/server';
import SeoFields from '../../../components/admin/SeoFields.astro';

const supabase = createSupabaseAdminClient();
const { id }   = Astro.params;

let successMsg = Astro.url.searchParams.get('ok') === '1'
  ? 'Prodotto aggiornato con successo!'
  : '';
let errorMsg   = '';

// ─── Carica prodotto + categorie + tag ───────────────────────────────────────
const [
  { data: prodotto, error: fetchErr },
  { data: categorie },
  { data: tagDisponibili },
] = await Promise.all([
  supabase.from('prodotti')
    .select('id, nome, prezzo, prezzo_originale, descrizione, anteprima, file_path, slug, seo_titolo, seo_descrizione, seo_og_image, categoria_id')
    .eq('id', id).single(),
  supabase.from('categorie').select('id, nome').in('tipo', ['shop','both']).order('nome'),
  supabase.from('tag').select('id, nome').in('tipo', ['shop','both']).order('nome'),
]);

if (fetchErr || !prodotto) return Astro.redirect('/admin/prodotti');

const { data: tagProdotto } = await supabase
  .from('prodotti_tag').select('tag_id').eq('prodotto_id', id);
const tagProdottoIds = new Set((tagProdotto ?? []).map((t: any) => t.tag_id));

const anteprimaEsistente   = prodotto.anteprima   ?? '';
const descrizioneEsistente = prodotto.descrizione ?? '';
---

<AdminLayout title={`Modifica: ${prodotto.nome}`} activeNav="prodotti">

  <div class="mb-6">
    <a href="/admin/prodotti"
      class="text-xs uppercase tracking-widest transition-colors"
      style="color: var(--text-muted);"
      onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--text-muted)'">
      ← Torna ai prodotti
    </a>
  </div>

  {successMsg && (
    <div class="mb-6 rounded-xl border border-green-600/40 bg-green-600/10 px-5 py-3 text-sm text-green-400">{successMsg}</div>
  )}
  {errorMsg && (
    <div class="mb-6 rounded-xl border border-red-600/40 bg-red-600/10 px-5 py-3 text-sm text-red-400">{errorMsg}</div>
  )}

  <section class="rounded-2xl border p-8" style="border-color: var(--border); background-color: color-mix(in srgb, var(--surface) 40%, transparent);">
    <form id="form-modifica-prodotto" class="space-y-5">

      <div class="grid gap-5 sm:grid-cols-3">
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">Nome prodotto *</label>
          <input type="text" name="nome" required value={prodotto.nome} class="auth-input w-full" />
        </div>
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">Prezzo (€) *</label>
          <input type="number" name="prezzo" required min="0.01" step="0.01"
            value={Number(prodotto.prezzo).toFixed(2)} class="auth-input w-full" />
        </div>
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
            Prezzo originale (€) <span class="normal-case font-normal" style="color:var(--text-muted);">— barrato</span>
          </label>
          <input type="number" name="prezzo_originale" min="0.01" step="0.01"
            value={prodotto.prezzo_originale ? Number(prodotto.prezzo_originale).toFixed(2) : ''}
            placeholder="49.00"
            class="auth-input w-full" />
          <p class="mt-1 text-xs" style="color:var(--text-muted);">Lascia vuoto per rimuovere lo sconto.</p>
        </div>
      </div>

      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
          Descrizione breve <span class="normal-case" style="color:var(--text-muted);">(appare sulle card)</span>
        </label>
        <textarea name="descrizione" rows="2" class="auth-input w-full resize-y">{descrizioneEsistente}</textarea>
      </div>

      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
          Testo di vendita <span class="normal-case" style="color:var(--text-muted);">— sempre visibile a tutti, usa per convincere all'acquisto</span>
        </label>
        <div id="editor-anteprima" style="min-height: 220px;"></div>
      </div>

      <div>
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color: var(--text-muted);">
          Sostituisci PDF <span class="normal-case" style="color:var(--text-muted);">(lascia vuoto per mantenere quello attuale)</span>
        </label>
        {prodotto.file_path && (
          <p class="mb-2 text-xs font-mono" style="color:var(--gold);">
            Attuale: {prodotto.file_path.split('/').pop()}
          </p>
        )}
        <div class="flex items-center gap-4 rounded-xl border-2 border-dashed px-5 py-5 transition-colors duration-200"
          style="border-color: var(--border);">
          <input type="file" name="pdf" accept=".pdf,application/pdf" id="pdf-input"
            class="absolute opacity-0" style="width:1px; height:1px;" />
          <label for="pdf-input"
            class="cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-widest transition-all duration-200"
            style="background-color: var(--gold); color: #0F0D0A;">
            Scegli nuovo PDF
          </label>
          <p id="pdf-filename" class="text-xs" style="color:var(--gold);"></p>
        </div>
      </div>

      <!-- Categoria + Tag -->
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color:var(--text-muted);">Categoria</label>
          <select name="categoria_id" class="auth-input w-full">
            <option value="">— Nessuna categoria —</option>
            {(categorie ?? []).map((c: any) => (
              <option value={c.id} selected={prodotto.categoria_id === c.id}>{c.nome}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-widest" style="color:var(--text-muted);">Tag</label>
          <div class="flex flex-wrap gap-2 rounded-xl border p-3" style="border-color:var(--border); background-color:var(--bg);">
            {(tagDisponibili ?? []).map((t: any) => (
              <label class="flex cursor-pointer items-center gap-1.5 rounded-full border px-2.5 py-1 text-xs transition-colors"
                style={`border-color:${tagProdottoIds.has(t.id) ? 'var(--gold)' : 'var(--border)'}; color:${tagProdottoIds.has(t.id) ? 'var(--gold)' : 'var(--text-muted)'};`}
                id={`tag-lbl-${t.id}`}>
                <input type="checkbox" name="tag_ids" value={t.id}
                  checked={tagProdottoIds.has(t.id)} class="sr-only"
                  onchange={`var l=document.getElementById('tag-lbl-${t.id}');l.style.borderColor=this.checked?'var(--gold)':'var(--border)';l.style.color=this.checked?'var(--gold)':'var(--text-muted)';`} />
                {t.nome}
              </label>
            ))}
            {(tagDisponibili ?? []).length === 0 && (
              <p class="text-xs" style="color:var(--text-muted);">Nessun tag. <a href="/admin/categorie" style="color:var(--gold);">Creane uno →</a></p>
            )}
          </div>
        </div>
      </div>

      <SeoFields
        seoTitolo={prodotto.seo_titolo ?? ''}
        seoDescrizione={prodotto.seo_descrizione ?? ''}
        seoOgImage={prodotto.seo_og_image ?? ''}
        slug={prodotto.slug ?? ''}
      />

      <div class="pt-2">
        <button type="submit" id="btn-salva-prodotto" class="auth-submit">Salva modifiche</button>
        <p id="modifica-prodotto-msg" class="mt-3 hidden text-sm"></p>
      </div>
    </form>
  </section>

</AdminLayout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
<script is:inline define:vars={{ anteprimaEsistente, prodottoId: id }}>
(function () {
  const toolbarOptions = [
    [{ header: [1, 2, 3, false] }],
    [{ size: ['small', false, 'large', 'huge'] }],
    ['bold', 'italic', 'underline', 'strike'],
    [{ color: [] }, { background: [] }],
    [{ list: 'ordered' }, { list: 'bullet' }],
    ['blockquote', 'link'],
    ['clean'],
  ];

  const quill = new Quill('#editor-anteprima', {
    theme: 'snow',
    modules: { toolbar: toolbarOptions },
  });

  if (anteprimaEsistente) {
    quill.root.innerHTML = anteprimaEsistente;
  }

  function toB64(str) {
    return btoa(unescape(encodeURIComponent(str)));
  }

  function fileExt(name) {
    return (name.split('.').pop() || 'jpg').toLowerCase();
  }

  function fileToB64(file) {
    return new Promise(function(resolve, reject) {
      var reader = new FileReader();
      reader.onload = function() { resolve(String(reader.result).split(',')[1]); };
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  async function parseApiResponse(res) {
    var text = await res.text();
    try { return { ok: res.ok, data: JSON.parse(text) }; }
    catch (e) {
      throw new Error(res.status === 403 ? 'Bloccato dal firewall Vercel — riprova tra poco' : (text.slice(0, 120) || 'Errore server'));
    }
  }

  const form = document.getElementById('form-modifica-prodotto');
  const msgEl = document.getElementById('modifica-prodotto-msg');
  const btn = document.getElementById('btn-salva-prodotto');

  if (form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      const nome = form.querySelector('input[name="nome"]')?.value?.trim();
      const prezzo = parseFloat(form.querySelector('input[name="prezzo"]')?.value);
      if (!nome || isNaN(prezzo) || prezzo <= 0) {
        if (msgEl) { msgEl.style.color = '#ef4444'; msgEl.textContent = 'Nome e prezzo (> 0) sono obbligatori.'; msgEl.classList.remove('hidden'); }
        return;
      }

      if (btn) { btn.disabled = true; btn.textContent = 'Salvataggio…'; }
      if (msgEl) { msgEl.style.color = 'var(--text-muted)'; msgEl.textContent = 'Salvataggio in corso…'; msgEl.classList.remove('hidden'); }

      try {
        const pdfFile = document.getElementById('pdf-input')?.files?.[0];
        let pdfB64 = null;
        if (pdfFile && pdfFile.size > 0) {
          pdfB64 = await fileToB64(pdfFile);
        }

        const ogFile = form.querySelector('input[name="seo_og_image_file"]')?.files?.[0];
        const uploadPanel = document.getElementById('og-panel-upload');
        const isUploadTab = uploadPanel && !uploadPanel.classList.contains('hidden');
        let ogImageB64 = null;
        let ogImageExt = null;
        if (isUploadTab && ogFile && ogFile.size > 0) {
          ogImageB64 = await fileToB64(ogFile);
          ogImageExt = fileExt(ogFile.name);
        }

        const html = quill.root.innerHTML;
        const anteprima = html === '<p><br></p>' ? '' : html;
        const tagIds = Array.from(form.querySelectorAll('input[name="tag_ids"]:checked')).map(function(el) { return el.value; });

        const res = await fetch('/api/admin/prodotti', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            action: 'aggiorna',
            id: prodottoId,
            nome,
            descrizione: form.querySelector('textarea[name="descrizione"]')?.value?.trim() || null,
            anteprima_b64: anteprima ? toB64(anteprima) : null,
            prezzo,
            prezzo_originale: form.querySelector('input[name="prezzo_originale"]')?.value?.trim() || null,
            slug: form.querySelector('input[name="slug"]')?.value?.trim() || null,
            seo_titolo: form.querySelector('input[name="seo_titolo"]')?.value?.trim() || null,
            seo_descrizione: form.querySelector('textarea[name="seo_descrizione"]')?.value?.trim() || null,
            seo_og_image: form.querySelector('input[name="seo_og_image_url"]')?.value?.trim() || null,
            og_image_b64: ogImageB64,
            og_image_ext: ogImageExt,
            pdf_b64: pdfB64,
            categoria_id: form.querySelector('select[name="categoria_id"]')?.value?.trim() || null,
            tag_ids: tagIds,
          }),
        });

        const { ok, data } = await parseApiResponse(res);
        if (!ok) throw new Error(data.error || 'Errore salvataggio');

        window.location.href = window.location.pathname + '?ok=1';
      } catch (err) {
        if (msgEl) { msgEl.style.color = '#ef4444'; msgEl.textContent = '✗ ' + (err.message || 'Errore'); msgEl.classList.remove('hidden'); }
        if (btn) { btn.disabled = false; btn.textContent = 'Salva modifiche'; }
      }
    });
  }

  // PDF filename preview
  const pdfInput = document.getElementById('pdf-input');
  const pdfLabel = document.getElementById('pdf-filename');
  if (pdfInput && pdfLabel) {
    pdfInput.addEventListener('change', () => {
      const file = pdfInput.files?.[0];
      pdfLabel.textContent = file ? `✔ ${file.name} (${(file.size/1024/1024).toFixed(1)} MB)` : '';
    });
  }
})();
</script>
