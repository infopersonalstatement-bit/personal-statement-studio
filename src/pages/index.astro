---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/common/PageHero.astro';

const { data: prodotti } = await Astro.locals.supabase
  .from('prodotti')
  .select('id, nome, prezzo, prezzo_originale, descrizione, slug')
  .order('created_at', { ascending: false })
  .limit(4);
---

<BaseLayout
  title="Home"
  description="Ingegneria biologica e neurale per il business d'élite. Protocolli di precisione per chi governa la propria energia biologica e i propri risultati."
>

  <!-- ── HERO ──────────────────────────────────────────────────────────── -->
  <PageHero
    eyebrow="Personal Statement · Laboratory"
    subtitle="Riprendi il controllo del tuo sistema. Dalla ricalibrazione ormonale d'élite all'isolamento neuro-chimico. Protocolli di precisione per chi governa la propria energia biologica e i propri risultati."
    subtitleWide={true}
    ctaText="Accedi ai Protocolli"
    ctaHref="/shop"
    ctaSecondaryText="Dichiara il tuo Standard"
    ctaSecondaryHref="/manifesto"
    minHeight="100vh"
  >
    Ingegneria Biologica e Neurale<br />
    per il <em class="not-italic font-semibold" style="color: var(--gold);">Business d'Élite</em>.
  </PageHero>

  <!-- ── MISSIONE ─────────────────────────────────────────────────────── -->
  <section class="py-24" style="background-color: var(--bg-surface);">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">
        La nostra missione
      </p>
      <p class="font-display text-2xl font-light leading-relaxed sm:text-3xl" style="color: var(--text);">
        Non crediamo nella motivazione, nel sacrificio o nel conteggio ossessivo delle calorie.
        <span class="block mt-3" style="color: var(--gold);">Crediamo nell'intelligenza biologica applicata.</span>
      </p>
      <div class="mx-auto my-10 h-px w-24" style="background-color: var(--gold);"></div>
      <div class="space-y-5 text-left text-base leading-relaxed sm:text-center" style="color: var(--text-muted);">
        <p>
          La missione di Personal Statement è fornire l'architettura per operare all'eccellenza metabolica.
          Trasformiamo la mente reattiva in una <strong style="color: var(--gold);">mente direttiva</strong>,
          azzerando il debito biologico accumulato e ripristinando l'omeostasi strutturale.
        </p>
        <p>
          Il tuo corpo e la tua mente erano già progettati per funzionare alla perfezione:
          <strong style="color: var(--text);"> noi ti forniamo le istruzioni per ripristinarli.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- ── PILASTRI ───────────────────────────────────────────────────────── -->
  <section class="py-24 px-6">
    <div class="mx-auto max-w-6xl">
      <p class="mb-4 text-center text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">
        Perché sceglierci
      </p>
      <h2 class="font-display mb-16 text-center text-3xl font-light sm:text-4xl" style="color: var(--text);">
        Precisione. Nessun compromesso.
      </h2>

      <div class="grid gap-8 sm:grid-cols-3">
        {[
          {
            num: '01',
            title: 'Rifiuto del Compromesso',
            desc: 'Nessuna restrizione punitiva e nessun conteggio ossessivo — solo precisione ormonale e controllo metabolico d\'élite.',
          },
          {
            num: '02',
            title: 'Protezione della Mente Direttiva',
            desc: 'Insegniamo a sbloccare il controllo neurale e a intercettare il sequestro emotivo prima che comprometta le tue decisioni.',
          },
          {
            num: '03',
            title: 'Produttività Neuroscientifica',
            desc: 'Non offriamo gestione del tempo, ma ingegneria della concentrazione per creare slot di lavoro blindati e ad alto impatto.',
          },
        ].map((item) => (
          <div
            class="group rounded-2xl border p-8 transition-all duration-300"
            style="border-color: var(--border); background-color: var(--bg-card);"
            onmouseover="this.style.borderColor='var(--gold)'"
            onmouseout="this.style.borderColor='var(--border)'"
          >
            <p class="mb-4 font-display text-4xl font-light" style="color: var(--gold);">{item.num}</p>
            <h3 class="mb-3 text-sm font-semibold uppercase tracking-widest leading-snug" style="color: var(--text);">{item.title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PROTOCOLLI IN EVIDENZA ─────────────────────────────────────────── -->
  <section class="py-24 px-6" style="background-color: var(--bg-surface);">
    <div class="mx-auto max-w-6xl">
      <p class="mb-4 text-center text-xs font-semibold uppercase tracking-[0.3em]" style="color: var(--gold);">
        Protocolli di precisione
      </p>
      <h2 class="font-display mb-4 text-center text-3xl font-light sm:text-4xl" style="color: var(--text);">
        Il vault esclusivo.<br />
        <em class="not-italic font-semibold" style="color: var(--gold);">Accesso riservato.</em>
      </h2>
      <p class="mb-16 text-center text-sm max-w-2xl mx-auto leading-relaxed" style="color: var(--text-muted);">
        Sistemi documentati per decision makers che non possono permettersi di operare a capacità ridotta.
        Dalla ricalibrazione ormonale all'isolamento neuro-chimico.
      </p>

      {prodotti && prodotti.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {prodotti.map((p: any) => (
            <a
              href={`/shop/${p.slug ?? p.id}`}
              class="group flex flex-col rounded-2xl border p-6 transition-all duration-300"
              style="border-color: var(--border); background-color: var(--bg-card);"
              onmouseover="this.style.borderColor='var(--gold)'"
              onmouseout="this.style.borderColor='var(--border)'"
            >
              <h3 class="mb-3 text-sm font-semibold leading-snug" style="color: var(--text);">{p.nome}</h3>
              {p.descrizione && (
                <p class="mb-4 flex-1 text-xs leading-relaxed line-clamp-3" style="color: var(--text-muted);">{p.descrizione}</p>
              )}
              <div class="flex flex-wrap items-baseline gap-2">
                <p class="font-display text-2xl font-light" style="color: var(--gold);">€{Number(p.prezzo).toFixed(2)}</p>
                {p.prezzo_originale && p.prezzo_originale > p.prezzo && (
                  <>
                    <span class="font-display text-sm line-through" style="color: var(--text-muted);">
                      €{Number(p.prezzo_originale).toFixed(2)}
                    </span>
                    <span class="rounded-full px-2 py-0.5 text-[10px] font-bold uppercase"
                      style="background-color: color-mix(in srgb, var(--gold) 15%, transparent); color: var(--gold);">
                      -{Math.round((1 - p.prezzo / p.prezzo_originale) * 100)}%
                    </span>
                  </>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-center text-sm" style="color: var(--text-muted);">
          I protocolli saranno disponibili a breve.
        </p>
      )}

      <div class="mt-12 text-center">
        <a
          href="/shop"
          class="inline-block rounded-full border px-8 py-3 text-xs font-semibold uppercase tracking-widest transition-all"
          style="border-color: var(--gold); color: var(--gold);"
          onmouseover="this.style.backgroundColor='var(--gold)'; this.style.color='#0F0D0A'"
          onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--gold)'"
        >
          Accedi ai Protocolli →
        </a>
      </div>
    </div>
  </section>

  <!-- ── CTA FINALE ─────────────────────────────────────────────────────── -->
  <section class="py-32 px-6 text-center">
    <div class="mx-auto max-w-2xl">
      <p class="font-display mb-6 text-4xl font-light leading-tight sm:text-5xl" style="color: var(--text);">
        Dichiara il tuo<br />
        <em class="not-italic font-semibold" style="color: var(--gold);">Standard</em>.
      </p>
      <p class="mb-10 text-base leading-relaxed" style="color: var(--text-muted);">
        Per chi prende decisioni ad alto impatto e rifiuta di operare sotto il proprio potenziale biologico.
        Il laboratorio è aperto.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="/auth/registrazione"
          class="inline-block rounded-full px-10 py-4 text-sm font-semibold uppercase tracking-widest transition-all"
          style="background-color: var(--gold); color: #0F0D0A;"
          onmouseover="this.style.backgroundColor='var(--gold-hover)'"
          onmouseout="this.style.backgroundColor='var(--gold)'"
        >
          Dichiara il tuo Standard
        </a>
        <a
          href="/manifesto"
          class="inline-block rounded-full border px-8 py-4 text-sm font-semibold uppercase tracking-widest transition-all"
          style="border-color: var(--gold); color: var(--gold);"
          onmouseover="this.style.backgroundColor='var(--gold)'; this.style.color='#0F0D0A'"
          onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--gold)'"
        >
          Leggi il Manifesto
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
